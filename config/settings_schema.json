[
  {
    "name": "theme_info",
    "theme_name": "Prestige",
    "theme_version": "1.0.0",
    "theme_author": "Prestige Theme",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://help.shopify.com/manual/online-store/themes"
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "header",
        "content": "Base colors"
      },
      {
        "type": "color",
        "id": "color_background",
        "label": "Background",
        "default": "#ffffff"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Body text",
        "default": "#1a1a1a"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent (gold)",
        "default": "#c9a96e"
      },
      {
        "type": "header",
        "content": "Button colors"
      },
      {
        "type": "color",
        "id": "color_button",
        "label": "Button background",
        "default": "#c9a96e"
      },
      {
        "type": "color",
        "id": "color_button_text",
        "label": "Button text",
        "default": "#ffffff"
      },
      {
        "type": "header",
        "content": "Border & surface"
      },
      {
        "type": "color",
        "id": "color_border",
        "label": "Border",
        "default": "#e8e8e8"
      },
      {
        "type": "color",
        "id": "color_surface",
        "label": "Surface / Background secondary",
        "default": "#f8f7f5"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "type_header_font",
        "label": "Heading font",
        "default": "cormorant_garamond_n4"
      },
      {
        "type": "font_picker",
        "id": "type_body_font",
        "label": "Body font",
        "default": "jost_n4"
      },
      {
        "type": "range",
        "id": "font_body_size",
        "label": "Body font size",
        "min": 12,
        "max": 18,
        "step": 1,
        "default": 16,
        "unit": "px"
      },
      {
        "type": "header",
        "content": "Letter spacing"
      },
      {
        "type": "range",
        "id": "heading_letter_spacing",
        "label": "Heading letter spacing",
        "min": 0,
        "max": 20,
        "step": 1,
        "default": 2,
        "unit": "px",
        "info": "Additional letter-spacing for headings."
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "range",
        "id": "page_width",
        "label": "Page width",
        "min": 1000,
        "max": 1600,
        "step": 20,
        "default": 1280,
        "unit": "px"
      },
      {
        "type": "range",
        "id": "gutter_spacing",
        "label": "Container gutter (side padding)",
        "min": 16,
        "max": 64,
        "step": 4,
        "default": 32,
        "unit": "px"
      },
      {
        "type": "checkbox",
        "id": "round_buttons",
        "label": "Round buttons",
        "default": false,
        "info": "Adds rounded corners to all buttons."
      }
    ]
  },
  {
    "name": "Announcement bar",
    "settings": [
      {
        "type": "checkbox",
        "id": "show_announcement_bar",
        "default": true,
        "label": "Show announcement bar"
      },
      {
        "type": "text",
        "id": "announcement_text",
        "label": "Announcement text",
        "default": "Complimentary shipping & returns on all orders"
      },
      {
        "type": "url",
        "id": "announcement_link",
        "label": "Announcement link (optional)"
      }
    ]
  },
  {
    "name": "Favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon image",
        "info": "Recommended size: 32×32px PNG"
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "Cart type",
        "options": [
          { "value": "drawer", "label": "Slide-out drawer" },
          { "value": "page", "label": "Cart page" }
        ],
        "default": "drawer",
        "info": "Choose how the cart is displayed when a customer adds an item."
      }
    ]
  },
  {
    "name": "Social media",
    "settings": [
      {
        "type": "header",
        "content": "Social profiles"
      },
      {
        "type": "url",
        "id": "instagram_url",
        "label": "Instagram"
      },
      {
        "type": "url",
        "id": "facebook_url",
        "label": "Facebook"
      },
      {
        "type": "url",
        "id": "tiktok_url",
        "label": "TikTok"
      },
      {
        "type": "url",
        "id": "pinterest_url",
        "label": "Pinterest"
      },
      {
        "type": "url",
        "id": "twitter_url",
        "label": "Twitter / X"
      },
      {
        "type": "url",
        "id": "youtube_url",
        "label": "YouTube"
      }
    ]
  },
  {
    "name": "Media",
    "settings": [
      {
        "type": "header",
        "content": "Image behavior"
      },
      {
        "type": "checkbox",
        "id": "lazy_load_images",
        "default": true,
        "label": "Lazy load images",
        "info": "Improves page performance by loading images only when visible."
      },
      {
        "type": "select",
        "id": "product_image_ratio",
        "label": "Product image aspect ratio",
        "options": [
          { "value": "natural", "label": "Natural (from image)" },
          { "value": "square", "label": "Square (1:1)" },
          { "value": "portrait", "label": "Portrait (3:4)" },
          { "value": "landscape", "label": "Landscape (4:3)" }
        ],
        "default": "portrait"
      }
    ]
  },
  {
    "name": "Animations",
    "settings": [
      {
        "type": "checkbox",
        "id": "enable_animations",
        "default": true,
        "label": "Enable scroll animations",
        "info": "Sections fade in as users scroll down the page."
      }
    ]
  }
]
