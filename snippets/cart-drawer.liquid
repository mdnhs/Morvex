{% comment %}
  Cart Drawer — slides in from the right side.
  Rendered once in layout/theme.liquid.
  Cart content is populated/updated via JavaScript (CartDrawer class in theme.js).
{% endcomment %}

<!-- Cart Drawer Overlay -->
<div
  id="cart-drawer-overlay"
  class="cart-drawer-overlay"
  aria-hidden="true"
  tabindex="-1"
></div>

<!-- Cart Drawer -->
<div
  id="cart-drawer"
  class="cart-drawer"
  role="dialog"
  aria-modal="true"
  aria-label="{{ 'general.cart.title' | t }}"
  aria-hidden="true"
>

  <!-- Drawer Header -->
  <div class="cart-drawer__header">
    <div style="display:flex;align-items:center;">
      <h2 class="cart-drawer__title">{{ 'general.cart.title' | t }}</h2>
      <span class="cart-drawer__count">({{ cart.item_count }})</span>
    </div>
    <button
      class="cart-drawer__close"
      type="button"
      aria-label="{{ 'general.cart.close' | t | default: 'Close cart' }}"
    >
      {%- render 'icon', icon: 'close', size: 20 -%}
    </button>
  </div>

  <!-- Cart Items (populated by JS, but pre-rendered for no-JS fallback) -->
  <div class="cart-drawer__items" id="cart-drawer-items">
    {%- if cart.item_count == 0 -%}
      <div class="cart-drawer__empty">
        {%- render 'icon', icon: 'cart', size: 56, class: 'cart-drawer__empty-icon' -%}
        <h3 class="cart-drawer__empty-title">{{ 'general.cart.empty' | t | default: 'Your cart is empty' }}</h3>
        <p class="cart-drawer__empty-text">{{ 'general.cart.empty_subtitle' | t | default: 'Add some items to get started.' }}</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn--secondary btn--sm">
          {{ 'general.cart.continue_shopping' | t | default: 'Shop Now' }}
        </a>
      </div>
    {%- else -%}
      {%- for item in cart.items -%}
        {%- assign item_image = item.image | image_url: width: 200 | default: 'https://cdn.shopify.com/s/files/1/0533/2089/files/placeholder-images-product-3_large.png' -%}
        <div class="cart-drawer__item" data-key="{{ item.key }}">

          <!-- Item image -->
          <a href="{{ item.url }}" class="cart-drawer__item-image">
            <img
              src="{{ item_image }}"
              alt="{{ item.title | escape }}"
              loading="lazy"
              width="80"
              height="107"
            >
          </a>

          <!-- Item info -->
          <div class="cart-drawer__item-info">
            {%- if item.vendor != blank -%}
              <div class="cart-drawer__item-vendor">{{ item.vendor }}</div>
            {%- endif -%}

            <a href="{{ item.url }}" class="cart-drawer__item-title">{{ item.product_title }}</a>

            {%- unless item.variant.title == 'Default Title' -%}
              <div class="cart-drawer__item-variant">{{ item.variant.title }}</div>
            {%- endunless -%}

            {%- if item.selling_plan_allocation != blank -%}
              <div class="cart-drawer__item-variant">{{ item.selling_plan_allocation.selling_plan.name }}</div>
            {%- endif -%}

            <!-- Quantity Controls -->
            <div class="cart-drawer__item-qty">
              <button
                class="cart-drawer__item-qty-btn"
                type="button"
                data-action="decrease"
                data-line-key="{{ item.key }}"
                aria-label="{{ 'cart.decrease_quantity' | t | default: 'Decrease quantity' }}"
              >−</button>
              <input
                type="number"
                class="cart-drawer__item-qty-val"
                value="{{ item.quantity }}"
                min="0"
                data-line-key="{{ item.key }}"
                aria-label="{{ 'cart.item_quantity' | t | default: 'Quantity' }}"
              >
              <button
                class="cart-drawer__item-qty-btn"
                type="button"
                data-action="increase"
                data-line-key="{{ item.key }}"
                aria-label="{{ 'cart.increase_quantity' | t | default: 'Increase quantity' }}"
              >+</button>
            </div>

            <button
              class="cart-drawer__item-remove"
              type="button"
              data-line-key="{{ item.key }}"
            >
              {{ 'cart.remove' | t | default: 'Remove' }}
            </button>
          </div>

          <!-- Item price -->
          <div class="cart-drawer__item-price">
            {{ item.final_line_price | money }}
          </div>

        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>

  <!-- Drawer Footer -->
  <div class="cart-drawer__footer" {%- if cart.item_count == 0 -%} style="display:none;" {%- endif -%}>

    <!-- Subtotal -->
    <div class="cart-drawer__subtotal">
      <span class="cart-drawer__subtotal-label">{{ 'cart.subtotal' | t | default: 'Subtotal' }}</span>
      <span class="cart-drawer__subtotal-price" id="cart-drawer-subtotal">
        {{ cart.total_price | money }}
      </span>
    </div>

    <p class="cart-drawer__shipping">
      {{ 'cart.shipping_note' | t | default: 'Shipping & taxes calculated at checkout' }}
    </p>

    <!-- Actions -->
    <div class="cart-drawer__actions">
      <a href="{{ routes.checkout_url }}" class="btn btn--primary btn--full">
        {{ 'cart.checkout' | t | default: 'Checkout' }}
        &mdash; {{ cart.total_price | money }}
      </a>
      <a href="{{ routes.cart_url }}" class="btn btn--ghost btn--full">
        {{ 'cart.view_cart' | t | default: 'View Cart' }}
      </a>
    </div>

  </div>

</div>
