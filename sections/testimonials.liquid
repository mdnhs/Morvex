{% comment %}
  Testimonials section — customer quotes with star ratings.
  Grid on desktop, horizontal scroll on mobile.
{% endcomment %}

<section
  class="testimonials section"
  id="section-testimonials-{{ section.id }}"
  aria-label="{{ section.settings.heading | default: 'Customer testimonials' | escape }}"
>
  <div class="container">

    <!-- Section Header -->
    {%- if section.settings.heading != blank -%}
      <div class="section-header fade-in">
        {%- if section.settings.eyebrow != blank -%}
          <p class="section-header__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        <h2 class="section-header__title">{{ section.settings.heading }}</h2>
        {%- if section.settings.subheading != blank -%}
          <p class="section-header__subtitle">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <!-- Desktop Grid -->
    {%- if section.blocks.size > 0 -%}
      <div
        class="testimonials__grid"
        role="list"
        aria-label="{{ 'sections.testimonials.list_label' | t | default: 'Customer reviews' }}"
      >
        {%- for block in section.blocks -%}
          {%- assign rating = block.settings.rating | default: 5 -%}
          <article
            class="testimonial-card fade-in fade-in--delay-{{ forloop.index | modulo: 3 | plus: 1 }}"
            {{ block.shopify_attributes }}
            role="listitem"
          >
            <!-- Stars -->
            <div class="testimonial-card__stars" aria-label="{{ rating }} out of 5 stars" role="img">
              {%- for i in (1..5) -%}
                {%- if i <= rating -%}
                  {%- render 'icon', icon: 'star', size: 16, class: 'testimonial-card__star' -%}
                {%- else -%}
                  {%- render 'icon', icon: 'star-empty', size: 16, class: 'testimonial-card__star testimonial-card__star--empty' -%}
                {%- endif -%}
              {%- endfor -%}
            </div>

            <!-- Quote -->
            {%- if block.settings.quote != blank -%}
              <blockquote class="testimonial-card__quote">
                {{ block.settings.quote | escape }}
              </blockquote>
            {%- endif -%}

            <!-- Author -->
            <div class="testimonial-card__author">
              {%- if block.settings.author != blank -%}
                <p class="testimonial-card__name">{{ block.settings.author }}</p>
              {%- endif -%}
              {%- if block.settings.author_title != blank -%}
                <p class="testimonial-card__role">{{ block.settings.author_title }}</p>
              {%- endif -%}
            </div>

          </article>
        {%- endfor -%}
      </div>

      <!-- Mobile horizontal scroll -->
      <div
        class="testimonials__scroll"
        role="list"
        aria-label="{{ 'sections.testimonials.list_label' | t | default: 'Customer reviews' }}"
      >
        {%- for block in section.blocks -%}
          {%- assign rating = block.settings.rating | default: 5 -%}
          <article
            class="testimonial-card"
            {{ block.shopify_attributes }}
            role="listitem"
          >
            <div class="testimonial-card__stars" aria-label="{{ rating }} out of 5 stars" role="img">
              {%- for i in (1..5) -%}
                {%- if i <= rating -%}
                  {%- render 'icon', icon: 'star', size: 16, class: 'testimonial-card__star' -%}
                {%- else -%}
                  {%- render 'icon', icon: 'star-empty', size: 16, class: 'testimonial-card__star testimonial-card__star--empty' -%}
                {%- endif -%}
              {%- endfor -%}
            </div>
            {%- if block.settings.quote != blank -%}
              <blockquote class="testimonial-card__quote">{{ block.settings.quote | escape }}</blockquote>
            {%- endif -%}
            <div class="testimonial-card__author">
              {%- if block.settings.author != blank -%}
                <p class="testimonial-card__name">{{ block.settings.author }}</p>
              {%- endif -%}
              {%- if block.settings.author_title != blank -%}
                <p class="testimonial-card__role">{{ block.settings.author_title }}</p>
              {%- endif -%}
            </div>
          </article>
        {%- endfor -%}
      </div>

    {%- else -%}
      <!-- Editor placeholder -->
      <p style="text-align:center;color:var(--color-text-lighter);padding:var(--space-12) 0;">
        {{ 'sections.testimonials.add_blocks' | t | default: 'Add testimonial blocks in the section settings.' }}
      </p>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "class": "section-testimonials",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "What Our Customers Say"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Loved by Thousands"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "text",
          "id": "quote",
          "label": "Quote",
          "default": "The quality is exceptional. I've never owned anything quite like it — the craftsmanship speaks for itself. Truly a luxury experience from purchase to delivery."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author name",
          "default": "Sophia L."
        },
        {
          "type": "text",
          "id": "author_title",
          "label": "Author title or location",
          "default": "Verified Customer"
        },
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5,
          "label": "Star rating"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "settings": {
        "heading": "Loved by Thousands"
      },
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "quote": "The quality is exceptional. I've never owned anything quite like it — the craftsmanship speaks for itself.",
            "author": "Sophia L.",
            "author_title": "Verified Customer",
            "rating": 5
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "From the moment it arrived, I knew this was something special. The packaging alone told me everything about the brand's values.",
            "author": "Marcus T.",
            "author_title": "Verified Customer",
            "rating": 5
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "I've been searching for this level of quality for years. The attention to detail is extraordinary. This is my fifth purchase and each one has been perfect.",
            "author": "Isabelle R.",
            "author_title": "Loyal Customer",
            "rating": 5
          }
        }
      ]
    }
  ]
}
{% endschema %}
