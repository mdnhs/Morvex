{% comment %}
  Image with Text section — side-by-side image and editorial content.
{% endcomment %}

{%- liquid
  assign layout_class = 'image-with-text__inner--image-first'
  if section.settings.layout == 'text_first'
    assign layout_class = 'image-with-text__inner--text-first'
  endif

  assign width_class = ''
  case section.settings.image_width
    when '40'
      assign width_class = 'image-with-text__inner--40'
    when '60'
      assign width_class = 'image-with-text__inner--60'
  endcase
-%}

<section
  class="image-with-text section"
  id="section-image-with-text-{{ section.id }}"
  style="background-color:{{ section.settings.background_color | default: '#ffffff' }}; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;"
  aria-label="{{ section.settings.heading | default: 'Image with text' | escape }}"
>
  <div class="container">
    <div class="image-with-text__inner {{ layout_class }} {{ width_class }}">

      <!-- Image -->
      <div class="image-with-text__media fade-in-left">
        {%- if section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 900 }}"
            srcset="
              {{ section.settings.image | image_url: width: 550 }} 550w,
              {{ section.settings.image | image_url: width: 720 }} 720w,
              {{ section.settings.image | image_url: width: 900 }} 900w
            "
            sizes="(max-width: 768px) 100vw, 50vw"
            alt="{{ section.settings.image.alt | default: section.settings.heading | escape }}"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
            loading="lazy"
          >
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-icon' }}
        {%- endif -%}
      </div>

      <!-- Text Content -->
      <div class="image-with-text__content fade-in-right">
        {%- if section.settings.eyebrow != blank -%}
          <p class="image-with-text__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="image-with-text__title">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- if section.settings.show_divider -%}
          <div class="divider divider--left" aria-hidden="true"></div>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <div class="image-with-text__body richtext">
            {{ section.settings.text }}
          </div>
        {%- endif -%}

        <!-- Feature points -->
        {%- if section.settings.feature_1 != blank or section.settings.feature_2 != blank or section.settings.feature_3 != blank -%}
          <ul style="list-style:none;margin-bottom:var(--space-8);display:flex;flex-direction:column;gap:var(--space-3);">
            {%- if section.settings.feature_1 != blank -%}
              <li style="display:flex;align-items:center;gap:var(--space-3);font-size:var(--text-sm);">
                {%- render 'icon', icon: 'check', size: 16, class: 'text-accent' -%}
                {{ section.settings.feature_1 }}
              </li>
            {%- endif -%}
            {%- if section.settings.feature_2 != blank -%}
              <li style="display:flex;align-items:center;gap:var(--space-3);font-size:var(--text-sm);">
                {%- render 'icon', icon: 'check', size: 16, class: 'text-accent' -%}
                {{ section.settings.feature_2 }}
              </li>
            {%- endif -%}
            {%- if section.settings.feature_3 != blank -%}
              <li style="display:flex;align-items:center;gap:var(--space-3);font-size:var(--text-sm);">
                {%- render 'icon', icon: 'check', size: 16, class: 'text-accent' -%}
                {{ section.settings.feature_3 }}
              </li>
            {%- endif -%}
          </ul>
        {%- endif -%}

        {%- if section.settings.button_label != blank -%}
          <a
            href="{{ section.settings.button_link | default: '#' }}"
            class="btn{% if section.settings.button_style == 'primary' %} btn--primary{% elsif section.settings.button_style == 'ghost' %} btn--ghost{% else %} btn--secondary{% endif %}"
          >
            {{ section.settings.button_label }}
            {%- render 'icon', icon: 'arrow-right', size: 16 -%}
          </a>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Image with Text",
  "tag": "section",
  "class": "section-image-with-text",
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_width",
      "label": "Image width",
      "options": [
        { "value": "40", "label": "Narrow (40%)" },
        { "value": "50", "label": "Even (50%)" },
        { "value": "60", "label": "Wide (60%)" }
      ],
      "default": "50"
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Art of Luxury"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Body text",
      "default": "<p>Each piece is thoughtfully designed and crafted from the finest materials. Our commitment to quality means every detail is considered — from the initial sketch to the finished product in your hands.</p>"
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "default": true,
      "label": "Show accent divider"
    },
    {
      "type": "header",
      "content": "Feature points"
    },
    {
      "type": "text",
      "id": "feature_1",
      "label": "Feature point 1"
    },
    {
      "type": "text",
      "id": "feature_2",
      "label": "Feature point 2"
    },
    {
      "type": "text",
      "id": "feature_3",
      "label": "Feature point 3"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "options": [
        { "value": "primary", "label": "Primary" },
        { "value": "secondary", "label": "Secondary" },
        { "value": "ghost", "label": "Ghost" }
      ],
      "default": "ghost"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Image position",
      "options": [
        { "value": "image_first", "label": "Image left, text right" },
        { "value": "text_first", "label": "Text left, image right" }
      ],
      "default": "image_first"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 20,
      "max": 160,
      "step": 8,
      "default": 80,
      "unit": "px",
      "label": "Top padding"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 20,
      "max": 160,
      "step": 8,
      "default": 80,
      "unit": "px",
      "label": "Bottom padding"
    }
  ],
  "presets": [
    {
      "name": "Image with Text",
      "settings": {
        "heading": "The Art of Luxury",
        "layout": "image_first"
      }
    }
  ]
}
{% endschema %}
