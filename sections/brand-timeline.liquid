{% comment %}
  Brand Timeline section — alternating left/right milestones.
{% endcomment %}

<section
  class="brand-timeline section"
  id="section-brand-timeline-{{ section.id }}"
  aria-label="{{ section.settings.heading | default: 'Our Story' | escape }}"
>
  <div class="container">

    <div class="brand-timeline__header section-header fade-in">
      {%- if section.settings.eyebrow != blank -%}
        <p class="section-header__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="section-header__title">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="section-header__subtitle">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="timeline">
        {%- for block in section.blocks -%}
          <div class="timeline__item fade-in" {{ block.shopify_attributes }}>
            <div class="timeline__year">{{ block.settings.year }}</div>
            <div class="timeline__dot" aria-hidden="true"></div>
            <div class="timeline__content">
              {%- if block.settings.title != blank -%}
                <p class="timeline__event-title">{{ block.settings.title }}</p>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <p class="timeline__event-desc">{{ block.settings.description }}</p>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Brand Timeline",
  "tag": "section",
  "class": "section-brand-timeline",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Our History"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "A Legacy of Craft"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    }
  ],
  "blocks": [
    {
      "type": "milestone",
      "name": "Milestone",
      "settings": [
        {
          "type": "text",
          "id": "year",
          "label": "Year",
          "default": "2013"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Event title",
          "default": "Founded"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Our story begins with a simple idea: to create pieces of enduring quality."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand Timeline",
      "blocks": [
        { "type": "milestone", "settings": { "year": "2013", "title": "Founded", "description": "Our story begins with a single workshop and a commitment to craft." } },
        { "type": "milestone", "settings": { "year": "2015", "title": "First Collection", "description": "The debut collection launches to critical acclaim, selling out within days." } },
        { "type": "milestone", "settings": { "year": "2017", "title": "International Expansion", "description": "We open our first flagship store in Paris and begin shipping worldwide." } },
        { "type": "milestone", "settings": { "year": "2019", "title": "Sustainability Pledge", "description": "We commit to 100% ethically sourced materials across all collections." } },
        { "type": "milestone", "settings": { "year": "2021", "title": "Award Winning", "description": "Named one of the world's most innovative luxury brands by a leading industry journal." } }
      ]
    }
  ]
}
{% endschema %}
