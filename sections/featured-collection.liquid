{% comment %}
  Featured Collection section — displays a grid of products from a selected collection.
{% endcomment %}

{%- liquid
  assign collection = collections[section.settings.collection]
  assign products_to_show = section.settings.products_to_show | default: 8
  assign columns = section.settings.columns_desktop | default: 4

  assign grid_class = 'product-grid'
  if columns == 3
    assign grid_class = 'product-grid product-grid--3'
  elsif columns == 2
    assign grid_class = 'product-grid product-grid--2'
  endif
-%}

<section
  class="featured-collection section"
  id="section-featured-collection-{{ section.id }}"
  aria-label="{{ section.settings.title | default: 'Featured products' | escape }}"
>
  <div class="container">

    <!-- Section Header -->
    {%- if section.settings.title != blank or section.settings.subtitle != blank -%}
      <div class="section-header fade-in">
        {%- if section.settings.eyebrow != blank -%}
          <p class="section-header__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 class="section-header__title">{{ section.settings.title }}</h2>
        {%- endif -%}
        {%- if section.settings.subtitle != blank -%}
          <p class="section-header__subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <!-- Product Grid -->
    {%- if collection != blank and collection.products.size > 0 -%}
      <div class="{{ grid_class }}" role="list">
        {%- for product in collection.products limit: products_to_show -%}
          <div class="fade-in fade-in--delay-{{ forloop.index | modulo: 4 | plus: 1 }}" role="listitem">
            {%- render 'product-card',
              product: product,
              show_vendor: section.settings.show_vendor,
              show_quick_add: section.settings.show_quick_add,
              index: forloop.index
            -%}
          </div>
        {%- endfor -%}
      </div>
    {%- elsif collection == blank -%}
      <!-- Placeholder when no collection is set in the editor -->
      <div class="{{ grid_class }}" role="list">
        {%- for i in (1..products_to_show) -%}
          <div class="product-card fade-in fade-in--delay-{{ forloop.index | modulo: 4 | plus: 1 }}" role="listitem">
            <div class="product-card__media">
              {{ 'product-' | append: i | placeholder_svg_tag: 'product-card__image product-card__image--primary' }}
            </div>
            <div class="product-card__info">
              <span class="product-card__title">Sample Product {{ i }}</span>
              <div class="product-card__price">
                <span class="product-card__price-regular">$120.00</span>
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- else -%}
      <p style="text-align:center;color:var(--color-text-lighter);padding:var(--space-12) 0;">
        {{ 'sections.featured_collection.empty' | t | default: 'This collection is empty.' }}
      </p>
    {%- endif -%}

    <!-- View All Button -->
    {%- if section.settings.show_view_all and collection != blank -%}
      <div class="section-footer fade-in">
        <a href="{{ collection.url }}" class="btn btn--ghost">
          {{ section.settings.view_all_label | default: 'View All' }}
          {%- render 'icon', icon: 'arrow-right', size: 16 -%}
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Featured Collection",
  "tag": "section",
  "class": "section-featured-collection",
  "settings": [
    {
      "type": "header",
      "content": "Section heading"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "New Arrivals"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Featured Products"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subheading"
    },
    {
      "type": "header",
      "content": "Collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 12,
      "step": 2,
      "default": 8,
      "label": "Products to show"
    },
    {
      "type": "header",
      "content": "Grid layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4,
      "label": "Number of columns (desktop)"
    },
    {
      "type": "header",
      "content": "Product card options"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": false,
      "label": "Show vendor name"
    },
    {
      "type": "checkbox",
      "id": "show_quick_add",
      "default": true,
      "label": "Show quick-add button"
    },
    {
      "type": "header",
      "content": "View all button"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "default": true,
      "label": "Show 'View all' button"
    },
    {
      "type": "text",
      "id": "view_all_label",
      "default": "View All",
      "label": "'View all' button label"
    }
  ],
  "presets": [
    {
      "name": "Featured Collection",
      "settings": {
        "title": "Featured Products",
        "products_to_show": 8,
        "columns_desktop": 4
      }
    }
  ]
}
{% endschema %}
