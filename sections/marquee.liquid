{% comment %}
  Marquee — infinite scrolling ticker text
{% endcomment %}

{%- liquid
  assign bg = section.settings.background | default: 'dark'
  assign speed = section.settings.speed | default: 30
-%}

<style>
  #shopify-section-{{ section.id }} {
    --marquee-bg: {% if bg == 'dark' %}#1c1c1c{% else %}#ffffff{% endif %};
    --marquee-color: {% if bg == 'dark' %}#ffffff{% else %}#1c1c1c{% endif %};
    --marquee-speed: {{ speed }}s;
  }
  .marquee-{{ section.id }} {
    background: var(--marquee-bg);
    color: var(--marquee-color);
    overflow: hidden;
    white-space: nowrap;
    padding: 1rem 0;
    border-top: 1px solid {% if bg == 'dark' %}rgba(255,255,255,0.1){% else %}#e8e8e8{% endif %};
    border-bottom: 1px solid {% if bg == 'dark' %}rgba(255,255,255,0.1){% else %}#e8e8e8{% endif %};
  }
  .marquee-{{ section.id }}__track {
    display: inline-flex;
    animation: marquee-{{ section.id }} var(--marquee-speed) linear infinite;
    will-change: transform;
  }
  .marquee-{{ section.id }}:hover .marquee-{{ section.id }}__track {
    animation-play-state: paused;
  }
  .marquee-{{ section.id }}__item {
    display: inline-flex;
    align-items: center;
    font-family: 'Instrument Sans', sans-serif;
    font-size: clamp(0.75rem, 1.5vw, 0.875rem);
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 0 2rem;
    gap: 2rem;
  }
  .marquee-{{ section.id }}__sep {
    display: inline-block;
    opacity: 0.4;
    font-size: 0.6em;
  }
  @keyframes marquee-{{ section.id }} {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
</style>

<div class="marquee-{{ section.id }}" aria-hidden="true">
  <div class="marquee-{{ section.id }}__track">
    {%- comment %} Duplicate 4x for seamless loop {%- endcomment %}
    {%- for _rep in (1..4) -%}
      {%- for block in section.blocks -%}
        <span class="marquee-{{ section.id }}__item" {{ block.shopify_attributes }}>
          {{ block.settings.text | escape }}
          <span class="marquee-{{ section.id }}__sep">&#10022;</span>
        </span>
      {%- endfor -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Marquee",
  "tag": "section",
  "class": "section-marquee",
  "max_blocks": 8,
  "settings": [
    {
      "type": "select",
      "id": "background",
      "label": "Background",
      "options": [
        { "value": "dark", "label": "Dark" },
        { "value": "light", "label": "Light" }
      ],
      "default": "dark"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll speed (seconds per loop)",
      "min": 10,
      "max": 60,
      "step": 5,
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Text item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "New Arrivals"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Marquee",
      "blocks": [
        { "type": "item", "settings": { "text": "New: Le Sac Baguette" } },
        { "type": "item", "settings": { "text": "Shop New Arrivals" } },
        { "type": "item", "settings": { "text": "Free Shipping Over $150" } }
      ]
    }
  ]
}
{% endschema %}
