{% comment %}
  Slideshow section — full-width hero carousel with multiple slides.
  Supports countdown timer, autoplay, prev/next arrows, dot indicators.
{% endcomment %}

{%- liquid
  assign height_class = 'slideshow--full'
  case section.settings.height
    when 'large'
      assign height_class = 'slideshow--large'
    when 'medium'
      assign height_class = 'slideshow--medium'
  endcase
-%}

<section
  class="slideshow {{ height_class }}"
  id="section-slideshow-{{ section.id }}"
  data-autoplay="{{ section.settings.autoplay }}"
  data-interval="{{ section.settings.autoplay_speed | times: 1000 }}"
  aria-label="{{ 'sections.slideshow.title' | t | default: 'Slideshow' }}"
  aria-roledescription="carousel"
>

  {%- if section.blocks.size > 0 -%}

    <!-- Slides Track -->
    <div class="slideshow__track" id="slideshow-track-{{ section.id }}" aria-live="polite">
      {%- for block in section.blocks -%}
        {%- liquid
          assign text_color = block.settings.text_color | default: 'white'
          assign content_pos = block.settings.content_position | default: 'center'
          assign has_countdown = false
          if block.settings.countdown_date != blank
            assign has_countdown = true
          endif
        -%}
        <div
          class="slideshow__slide"
          {{ block.shopify_attributes }}
          role="group"
          aria-roledescription="slide"
          aria-label="{{ forloop.index }} / {{ section.blocks.size }}"
          aria-hidden="{% if forloop.first %}false{% else %}true{% endif %}"
        >
          <!-- Background -->
          <div class="slideshow__media">
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 1920 }}"
                srcset="
                  {{ block.settings.image | image_url: width: 750 }} 750w,
                  {{ block.settings.image | image_url: width: 1100 }} 1100w,
                  {{ block.settings.image | image_url: width: 1500 }} 1500w,
                  {{ block.settings.image | image_url: width: 1920 }} 1920w
                "
                sizes="100vw"
                alt="{{ block.settings.image.alt | default: block.settings.heading | escape }}"
                loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                fetchpriority="{% if forloop.first %}high{% else %}auto{% endif %}"
              >
            {%- else -%}
              <div style="width:100%;height:100%;background:linear-gradient(135deg,#142e2b 0%,#1c1c1c 100%);"></div>
            {%- endif -%}
          </div>

          <!-- Overlay -->
          <div
            class="slideshow__overlay"
            style="opacity:{{ block.settings.overlay_opacity | divided_by: 100.0 }};"
            aria-hidden="true"
          ></div>

          <!-- Content -->
          <div
            class="slideshow__content slideshow__content--{{ content_pos }}"
            style="color:{% if text_color == 'dark' %}#1c1c1c{% else %}#ffffff{% endif %};"
          >
            <div class="slideshow__inner">

              {%- if has_countdown -%}
                <div
                  class="slideshow__countdown fade-in"
                  data-countdown="{{ block.settings.countdown_date }}"
                >
                  <div class="slideshow__countdown-item">
                    <span class="slideshow__countdown-num" data-days>00</span>
                    <span class="slideshow__countdown-label">Days</span>
                  </div>
                  <div class="slideshow__countdown-item">
                    <span class="slideshow__countdown-num" data-hours>00</span>
                    <span class="slideshow__countdown-label">Hours</span>
                  </div>
                  <div class="slideshow__countdown-item">
                    <span class="slideshow__countdown-num" data-minutes>00</span>
                    <span class="slideshow__countdown-label">Mins</span>
                  </div>
                  <div class="slideshow__countdown-item">
                    <span class="slideshow__countdown-num" data-seconds>00</span>
                    <span class="slideshow__countdown-label">Secs</span>
                  </div>
                </div>
              {%- endif -%}

              {%- if block.settings.eyebrow != blank -%}
                <p class="slideshow__eyebrow fade-in">{{ block.settings.eyebrow }}</p>
              {%- endif -%}

              {%- if block.settings.heading != blank -%}
                <h2 class="slideshow__title fade-in fade-in--delay-1">
                  {{ block.settings.heading }}
                </h2>
              {%- endif -%}

              {%- if block.settings.subheading != blank -%}
                <p class="slideshow__subtitle fade-in fade-in--delay-2">
                  {{ block.settings.subheading }}
                </p>
              {%- endif -%}

              <div class="slideshow__actions fade-in fade-in--delay-3">
                {%- if block.settings.button_label != blank -%}
                  <a
                    href="{{ block.settings.button_link | default: routes.all_products_collection_url }}"
                    class="btn {% if text_color == 'dark' %}btn--primary{% else %}btn--ghost-white{% endif %} btn--lg"
                  >
                    {{ block.settings.button_label }}
                  </a>
                {%- endif -%}
                {%- if block.settings.button2_label != blank -%}
                  <a
                    href="{{ block.settings.button2_link | default: routes.collections_url }}"
                    class="btn btn--ghost-white btn--lg"
                    style="{% if text_color == 'dark' %}border-color:#1c1c1c;color:#1c1c1c;{% else %}border-color:rgba(255,255,255,0.6);{% endif %}"
                  >
                    {{ block.settings.button2_label }}
                  </a>
                {%- endif -%}
              </div>

            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>

    <!-- Arrows -->
    {%- if section.settings.show_arrows and section.blocks.size > 1 -%}
      <button
        class="slideshow__arrow slideshow__arrow--prev"
        type="button"
        aria-label="{{ 'sections.slideshow.previous_slide' | t | default: 'Previous slide' }}"
        data-slideshow-prev
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <button
        class="slideshow__arrow slideshow__arrow--next"
        type="button"
        aria-label="{{ 'sections.slideshow.next_slide' | t | default: 'Next slide' }}"
        data-slideshow-next
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M7.5 5L12.5 10L7.5 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    {%- endif -%}

    <!-- Dots -->
    {%- if section.settings.show_dots and section.blocks.size > 1 -%}
      <div class="slideshow__controls" aria-label="{{ 'sections.slideshow.slide_count' | t | default: 'Slide navigation' }}">
        <div class="slideshow__dots" role="tablist">
          {%- for block in section.blocks -%}
            <button
              class="slideshow__dot{% if forloop.first %} is-active{% endif %}"
              type="button"
              role="tab"
              aria-label="{{ 'sections.slideshow.go_to_slide' | t: number: forloop.index | default: 'Go to slide ' | append: forloop.index }}"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              data-slideshow-dot="{{ forloop.index0 }}"
            ></button>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

  {%- else -%}
    <!-- Editor placeholder -->
    <div class="slideshow__media" style="height:80vh;background:#efefef;display:flex;align-items:center;justify-content:center;">
      <p style="font-size:var(--text-sm);color:var(--color-text-lighter);letter-spacing:0.15em;text-transform:uppercase;">Add slide blocks to get started</p>
    </div>
  {%- endif -%}

</section>

<script>
(function() {
  var section = document.getElementById('section-slideshow-{{ section.id }}');
  if (!section) return;

  var track = section.querySelector('.slideshow__track');
  var slides = section.querySelectorAll('.slideshow__slide');
  var dots = section.querySelectorAll('[data-slideshow-dot]');
  var prevBtn = section.querySelector('[data-slideshow-prev]');
  var nextBtn = section.querySelector('[data-slideshow-next]');
  var autoplay = section.dataset.autoplay === 'true';
  var interval = parseInt(section.dataset.interval) || 5000;

  var current = 0;
  var timer = null;

  function goTo(idx) {
    if (idx < 0) idx = slides.length - 1;
    if (idx >= slides.length) idx = 0;
    current = idx;
    track.style.transform = 'translateX(-' + (idx * 100) + '%)';
    slides.forEach(function(s, i) { s.setAttribute('aria-hidden', i !== idx ? 'true' : 'false'); });
    dots.forEach(function(d, i) {
      d.classList.toggle('is-active', i === idx);
      d.setAttribute('aria-selected', i === idx ? 'true' : 'false');
    });
  }

  if (prevBtn) prevBtn.addEventListener('click', function() { goTo(current - 1); resetTimer(); });
  if (nextBtn) nextBtn.addEventListener('click', function() { goTo(current + 1); resetTimer(); });
  dots.forEach(function(d) { d.addEventListener('click', function() { goTo(parseInt(d.dataset.slideshowDot)); resetTimer(); }); });

  function resetTimer() {
    if (!autoplay) return;
    clearInterval(timer);
    timer = setInterval(function() { goTo(current + 1); }, interval);
  }

  if (autoplay && slides.length > 1) {
    timer = setInterval(function() { goTo(current + 1); }, interval);
    section.addEventListener('mouseenter', function() { clearInterval(timer); });
    section.addEventListener('mouseleave', function() { resetTimer(); });
  }

  // Countdown timers
  section.querySelectorAll('[data-countdown]').forEach(function(el) {
    var target = new Date(el.dataset.countdown).getTime();
    function update() {
      var now = Date.now();
      var diff = target - now;
      if (diff <= 0) { el.remove(); return; }
      var days = Math.floor(diff / 86400000);
      var hours = Math.floor((diff % 86400000) / 3600000);
      var mins = Math.floor((diff % 3600000) / 60000);
      var secs = Math.floor((diff % 60000) / 1000);
      var pad = function(n) { return String(n).padStart(2, '0'); };
      el.querySelector('[data-days]').textContent = pad(days);
      el.querySelector('[data-hours]').textContent = pad(hours);
      el.querySelector('[data-minutes]').textContent = pad(mins);
      el.querySelector('[data-seconds]').textContent = pad(secs);
    }
    update();
    setInterval(update, 1000);
  });

  // Touch/swipe support
  var touchStartX = 0;
  section.addEventListener('touchstart', function(e) { touchStartX = e.touches[0].clientX; }, { passive: true });
  section.addEventListener('touchend', function(e) {
    var diff = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 50) { goTo(diff > 0 ? current + 1 : current - 1); resetTimer(); }
  });
})();
</script>

{% schema %}
{
  "name": "Slideshow",
  "tag": "section",
  "class": "section-slideshow",
  "max_blocks": 6,
  "settings": [
    {
      "type": "select",
      "id": "height",
      "label": "Slide height",
      "options": [
        { "value": "full", "label": "Full viewport (100vh)" },
        { "value": "large", "label": "Large (80vh)" },
        { "value": "medium", "label": "Medium (60vh)" }
      ],
      "default": "full"
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show arrow buttons",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show dot indicators",
      "default": true
    },
    {
      "type": "header",
      "content": "Autoplay"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Auto-rotate slides",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 3,
      "max": 10,
      "step": 1,
      "default": 5,
      "unit": "s",
      "label": "Change slides every"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "header",
          "content": "Image"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background image"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "min": 0,
          "max": 80,
          "step": 5,
          "default": 30,
          "unit": "%",
          "label": "Image overlay opacity"
        },
        {
          "type": "header",
          "content": "Content"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow text"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "New Collection"
        },
        {
          "type": "textarea",
          "id": "subheading",
          "label": "Subheading"
        },
        {
          "type": "header",
          "content": "Primary button"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        },
        {
          "type": "header",
          "content": "Secondary button"
        },
        {
          "type": "text",
          "id": "button2_label",
          "label": "Button label"
        },
        {
          "type": "url",
          "id": "button2_link",
          "label": "Button link"
        },
        {
          "type": "header",
          "content": "Layout"
        },
        {
          "type": "select",
          "id": "content_position",
          "label": "Content position",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ],
          "default": "center"
        },
        {
          "type": "select",
          "id": "text_color",
          "label": "Text color",
          "options": [
            { "value": "white", "label": "White" },
            { "value": "dark", "label": "Dark" }
          ],
          "default": "white"
        },
        {
          "type": "header",
          "content": "Countdown timer"
        },
        {
          "type": "text",
          "id": "countdown_date",
          "label": "End date & time",
          "info": "Format: YYYY-MM-DDTHH:MM:SS (e.g. 2026-04-01T00:00:00)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Slideshow",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "eyebrow": "New Season",
            "heading": "Le Sac Baguette",
            "subheading": "Discover the collection redefining modern luxury.",
            "button_label": "Shop Now",
            "button_link": "/collections/all",
            "content_position": "center",
            "text_color": "white",
            "overlay_opacity": 30
          }
        },
        {
          "type": "slide",
          "settings": {
            "eyebrow": "New Arrivals",
            "heading": "Le Nova",
            "subheading": "Crafted from the finest materials for the discerning individual.",
            "button_label": "Explore",
            "button_link": "/collections/all",
            "content_position": "center",
            "text_color": "white",
            "overlay_opacity": 30
          }
        }
      ]
    }
  ]
}
{% endschema %}
