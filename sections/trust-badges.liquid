{% comment %}
  Trust Badges — 4-column benefit blocks
{% endcomment %}

<style>
  .trust-badges-{{ section.id }} {
    border-top: 1px solid #e8e8e8;
    border-bottom: 1px solid #e8e8e8;
    background: #fff;
    padding: 2.5rem 0;
  }
  .trust-badges-{{ section.id }}__grid {
    display: grid;
    grid-template-columns: repeat({{ section.blocks.size | at_most: 4 }}, 1fr);
    gap: 0;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  .trust-badges-{{ section.id }}__item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1rem 1.5rem;
    border-right: 1px solid #e8e8e8;
  }
  .trust-badges-{{ section.id }}__item:last-child {
    border-right: none;
  }
  .trust-badges-{{ section.id }}__icon {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    color: #1c1c1c;
  }
  .trust-badges-{{ section.id }}__icon svg {
    width: 100%;
    height: 100%;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .trust-badges-{{ section.id }}__text {}
  .trust-badges-{{ section.id }}__heading {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #1c1c1c;
    margin: 0 0 0.35rem;
    line-height: 1.3;
  }
  .trust-badges-{{ section.id }}__desc {
    font-family: 'Nunito', sans-serif;
    font-size: 0.8125rem;
    color: #6b6b6b;
    margin: 0;
    line-height: 1.5;
  }
  @media (max-width: 767px) {
    .trust-badges-{{ section.id }}__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0;
      padding: 0 1rem;
    }
    .trust-badges-{{ section.id }}__item {
      padding: 1rem;
      border-right: 1px solid #e8e8e8;
      border-bottom: 1px solid #e8e8e8;
    }
    .trust-badges-{{ section.id }}__item:nth-child(2n) {
      border-right: none;
    }
    .trust-badges-{{ section.id }}__item:nth-last-child(-n+2) {
      border-bottom: none;
    }
  }
</style>

{%- assign delivery_icon = '<svg viewBox="0 0 24 24"><path d="M1 3h15v13H1zM16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>' -%}
{%- assign returns_icon = '<svg viewBox="0 0 24 24"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3"/></svg>' -%}
{%- assign support_icon = '<svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>' -%}
{%- assign payment_icon = '<svg viewBox="0 0 24 24"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>' -%}
{%- assign security_icon = '<svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>' -%}
{%- assign gift_icon = '<svg viewBox="0 0 24 24"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>' -%}

<div class="trust-badges-{{ section.id }}">
  <div class="trust-badges-{{ section.id }}__grid">
    {%- for block in section.blocks -%}
      {%- liquid
        assign icon_key = block.settings.icon | default: 'delivery'
        case icon_key
          when 'delivery'
            assign icon_svg = delivery_icon
          when 'returns'
            assign icon_svg = returns_icon
          when 'support'
            assign icon_svg = support_icon
          when 'payment'
            assign icon_svg = payment_icon
          when 'security'
            assign icon_svg = security_icon
          when 'gift'
            assign icon_svg = gift_icon
          else
            assign icon_svg = delivery_icon
        endcase
      -%}
      <div class="trust-badges-{{ section.id }}__item" {{ block.shopify_attributes }}>
        <div class="trust-badges-{{ section.id }}__icon" aria-hidden="true">
          {{ icon_svg }}
        </div>
        <div class="trust-badges-{{ section.id }}__text">
          {%- if block.settings.heading != blank -%}
            <p class="trust-badges-{{ section.id }}__heading">{{ block.settings.heading }}</p>
          {%- endif -%}
          {%- if block.settings.description != blank -%}
            <p class="trust-badges-{{ section.id }}__desc">{{ block.settings.description }}</p>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Trust Badges",
  "tag": "section",
  "class": "section-trust-badges",
  "max_blocks": 6,
  "settings": [],
  "blocks": [
    {
      "type": "badge",
      "name": "Badge",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "delivery", "label": "Delivery" },
            { "value": "returns", "label": "Returns" },
            { "value": "support", "label": "Support" },
            { "value": "payment", "label": "Payment" },
            { "value": "security", "label": "Security" },
            { "value": "gift", "label": "Gift" }
          ],
          "default": "delivery"
        },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Express delivery" },
        { "type": "text", "id": "description", "label": "Description", "default": "DHL express delivery worldwide" }
      ]
    }
  ],
  "presets": [{
    "name": "Trust Badges",
    "blocks": [
      { "type": "badge", "settings": { "icon": "delivery", "heading": "Express delivery", "description": "DHL express delivery worldwide" } },
      { "type": "badge", "settings": { "icon": "returns", "heading": "Free returns", "description": "Free returns for 30 days" } },
      { "type": "badge", "settings": { "icon": "support", "heading": "Customer service", "description": "Available via WhatsApp and email" } },
      { "type": "badge", "settings": { "icon": "payment", "heading": "Pay in 3x", "description": "Interest-free from $100" } }
    ]
  }]
}
{% endschema %}
