<section class="insta-{{ section.id }}">
  {%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
    <div class="insta-{{ section.id }}__header">
      {%- if section.settings.eyebrow != blank -%}
        <span class="insta-{{ section.id }}__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="insta-{{ section.id }}__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="insta-{{ section.id }}__grid">
    {%- for block in section.blocks -%}
      <a
        class="insta-{{ section.id }}__item"
        href="{{ block.settings.link | default: 'https://www.instagram.com' }}"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="View on Instagram"
        {{ block.shopify_attributes }}
      >
        {%- if block.settings.image != blank -%}
          {{ block.settings.image | image_url: width: 600 | image_tag: class: 'insta-' | append: section.id | append: '__img', loading: 'lazy', alt: 'Instagram post' }}
        {%- else -%}
          <div style="width:100%;height:100%;background:#e8e8e8;display:flex;align-items:center;justify-content:center;">
            {{ 'image' | placeholder_svg_tag: '' }}
          </div>
        {%- endif -%}
        <div class="insta-{{ section.id }}__overlay" aria-hidden="true">
          <span class="insta-{{ section.id }}__overlay-icon">{{ insta_icon }}</span>
        </div>
      </a>
    {%- endfor -%}
  </div>

  {%- if section.settings.view_label != blank and section.settings.instagram_handle != blank -%}
    <div class="insta-{{ section.id }}__footer">
      <a
        href="https://www.instagram.com/{{ section.settings.instagram_handle | remove: '@' }}"
        class="insta-{{ section.id }}__follow"
        target="_blank"
        rel="noopener noreferrer"
      >
        {{ section.settings.view_label }}
      </a>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Instagram",
  "tag": "section",
  "class": "section-instagram",
  "max_blocks": 9,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Instagram" },
    { "type": "text", "id": "heading", "label": "Handle", "default": "@yourhandle" },
    { "type": "text", "id": "instagram_handle", "label": "Instagram handle (for follow link)", "default": "yourhandle" },
    { "type": "text", "id": "view_label", "label": "Follow button label", "default": "Follow on Instagram" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 120, "step": 10, "default": 60, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 120, "step": 10, "default": 60, "unit": "px" }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "url", "id": "link", "label": "Link (Instagram post URL)" }
      ]
    }
  ],
  "presets": [{
    "name": "Instagram",
    "blocks": [
      {"type":"image"}, {"type":"image"}, {"type":"image"}, {"type":"image"}, {"type":"image"}
    ]
  }]
}
{% endschema %}
