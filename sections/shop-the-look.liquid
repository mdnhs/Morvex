{% comment %}
  Shop the Look — two lookbook panels with product pins
{% endcomment %}

<style>
  .stl-{{ section.id }} {
    padding: {{ section.settings.padding_top | default: 80 }}px 0 {{ section.settings.padding_bottom | default: 80 }}px;
    background: #fff;
  }
  .stl-{{ section.id }}__header {
    text-align: center;
    margin-bottom: 3rem;
  }
  .stl-{{ section.id }}__eyebrow {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #6b6b6b;
    margin-bottom: 0.6rem;
    display: block;
  }
  .stl-{{ section.id }}__heading {
    font-family: 'Instrument Sans', sans-serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #1c1c1c;
    margin: 0;
  }
  .stl-{{ section.id }}__grid {
    display: grid;
    grid-template-columns: repeat({{ section.blocks.size | at_most: 2 }}, 1fr);
    gap: 2px;
    max-width: 1400px;
    margin: 0 auto;
  }
  .stl-{{ section.id }}__panel {
    position: relative;
    overflow: visible;
    aspect-ratio: 3/4;
    background: #f0f0f0;
  }
  .stl-{{ section.id }}__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .stl-{{ section.id }}__panel-label {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: #fff;
    padding: 1rem 1.5rem;
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #1c1c1c;
  }
  /* Pin dots */
  .stl-{{ section.id }}__pin {
    position: absolute;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(255,255,255,0.9);
    border: 1.5px solid rgba(0,0,0,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transform: translate(-50%, -50%);
    z-index: 5;
    transition: background 0.2s, transform 0.2s;
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
  }
  .stl-{{ section.id }}__pin:hover { background: #fff; transform: translate(-50%, -50%) scale(1.1); }
  .stl-{{ section.id }}__pin svg { width: 14px; height: 14px; stroke: #1c1c1c; fill: none; stroke-width: 2; stroke-linecap: round; }
  /* Product popup */
  .stl-{{ section.id }}__popup {
    position: absolute;
    background: #fff;
    border: 1px solid #e8e8e8;
    padding: 1rem;
    width: 200px;
    z-index: 10;
    box-shadow: 0 8px 24px rgba(0,0,0,0.12);
    display: none;
    top: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
  }
  .stl-{{ section.id }}__pin.is-open .stl-{{ section.id }}__popup { display: block; }
  .stl-{{ section.id }}__popup-title {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #1c1c1c;
    margin: 0 0 0.25rem;
    line-height: 1.3;
  }
  .stl-{{ section.id }}__popup-price {
    font-family: 'Nunito', sans-serif;
    font-size: 0.875rem;
    color: #6b6b6b;
    margin: 0 0 0.75rem;
  }
  .stl-{{ section.id }}__popup-link {
    display: inline-block;
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #fff;
    background: #1c1c1c;
    padding: 0.5rem 0.875rem;
    text-decoration: none;
    transition: background 0.2s;
  }
  .stl-{{ section.id }}__popup-link:hover { background: #333; }
  @media (max-width: 767px) {
    .stl-{{ section.id }}__grid { grid-template-columns: 1fr; }
    .stl-{{ section.id }}__panel { aspect-ratio: 4/5; }
  }
</style>

<section class="stl-{{ section.id }}">
  {%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
    <div class="stl-{{ section.id }}__header container">
      {%- if section.settings.eyebrow != blank -%}
        <span class="stl-{{ section.id }}__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="stl-{{ section.id }}__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="stl-{{ section.id }}__grid">
    {%- for block in section.blocks -%}
      <div class="stl-{{ section.id }}__panel" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          <img class="stl-{{ section.id }}__img" src="{{ block.settings.image | image_url: width: 900 }}" alt="{{ block.settings.look_title | escape }}" loading="lazy" width="900" height="1200">
        {%- else -%}
          <div style="width:100%;height:100%;background:#e8e8e8;"></div>
        {%- endif -%}

        {%- comment %} Product pin 1 {%- endcomment %}
        {%- if block.settings.product_1 != blank -%}
          {%- assign p1 = all_products[block.settings.product_1] -%}
          {%- if p1 != blank -%}
            <div
              class="stl-{{ section.id }}__pin"
              style="left:{{ block.settings.product_1_x | default: 35 }}%;top:{{ block.settings.product_1_y | default: 40 }}%;"
              data-stl-pin
            >
              <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              <div class="stl-{{ section.id }}__popup">
                <p class="stl-{{ section.id }}__popup-title">{{ p1.title | truncate: 40 }}</p>
                <p class="stl-{{ section.id }}__popup-price">{{ p1.price | money }}</p>
                <a href="{{ p1.url }}" class="stl-{{ section.id }}__popup-link">View Product</a>
              </div>
            </div>
          {%- endif -%}
        {%- endif -%}

        {%- comment %} Product pin 2 {%- endcomment %}
        {%- if block.settings.product_2 != blank -%}
          {%- assign p2 = all_products[block.settings.product_2] -%}
          {%- if p2 != blank -%}
            <div
              class="stl-{{ section.id }}__pin"
              style="left:{{ block.settings.product_2_x | default: 65 }}%;top:{{ block.settings.product_2_y | default: 65 }}%;"
              data-stl-pin
            >
              <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              <div class="stl-{{ section.id }}__popup">
                <p class="stl-{{ section.id }}__popup-title">{{ p2.title | truncate: 40 }}</p>
                <p class="stl-{{ section.id }}__popup-price">{{ p2.price | money }}</p>
                <a href="{{ p2.url }}" class="stl-{{ section.id }}__popup-link">View Product</a>
              </div>
            </div>
          {%- endif -%}
        {%- endif -%}

        {%- if block.settings.look_title != blank -%}
          <div class="stl-{{ section.id }}__panel-label">{{ block.settings.look_title }}</div>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</section>

<script>
(function(){
  var pins = document.querySelectorAll('#shopify-section-{{ section.id }} [data-stl-pin]');
  pins.forEach(function(pin){
    pin.addEventListener('click', function(e){
      e.stopPropagation();
      var isOpen = pin.classList.contains('is-open');
      pins.forEach(function(p){ p.classList.remove('is-open'); });
      if (!isOpen) pin.classList.add('is-open');
    });
  });
  document.addEventListener('click', function(){ pins.forEach(function(p){ p.classList.remove('is-open'); }); });
})();
</script>

{% schema %}
{
  "name": "Shop the Look",
  "tag": "section",
  "class": "section-shop-the-look",
  "max_blocks": 2,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Lookbook" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop the Look" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 120, "step": 10, "default": 80, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 120, "step": 10, "default": 80, "unit": "px" }
  ],
  "blocks": [
    {
      "type": "look",
      "name": "Look",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Look image" },
        { "type": "text", "id": "look_title", "label": "Look title" },
        { "type": "header", "content": "Product pin 1" },
        { "type": "product", "id": "product_1", "label": "Product" },
        { "type": "range", "id": "product_1_x", "label": "Horizontal position", "min": 5, "max": 95, "step": 5, "default": 35, "unit": "%" },
        { "type": "range", "id": "product_1_y", "label": "Vertical position", "min": 5, "max": 95, "step": 5, "default": 40, "unit": "%" },
        { "type": "header", "content": "Product pin 2" },
        { "type": "product", "id": "product_2", "label": "Product" },
        { "type": "range", "id": "product_2_x", "label": "Horizontal position", "min": 5, "max": 95, "step": 5, "default": 65, "unit": "%" },
        { "type": "range", "id": "product_2_y", "label": "Vertical position", "min": 5, "max": 95, "step": 5, "default": 65, "unit": "%" }
      ]
    }
  ],
  "presets": [{ "name": "Shop the Look" }]
}
{% endschema %}
