{% comment %}
  Collaboration — two portrait images side by side with text overlay
{% endcomment %}

<style>
  .collab-{{ section.id }} {
    background: #fff;
    padding: {{ section.settings.padding_top | default: 60 }}px 0 {{ section.settings.padding_bottom | default: 60 }}px;
  }
  .collab-{{ section.id }}__header {
    text-align: center;
    max-width: 1280px;
    margin: 0 auto 2.5rem;
    padding: 0 2rem;
  }
  .collab-{{ section.id }}__eyebrow {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #6b6b6b;
    margin-bottom: 0.75rem;
    display: block;
  }
  .collab-{{ section.id }}__title {
    font-family: 'Instrument Sans', sans-serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #1c1c1c;
    margin: 0;
    line-height: 1.2;
  }
  .collab-{{ section.id }}__grid {
    display: grid;
    grid-template-columns: repeat({{ section.blocks.size | at_most: 2 }}, 1fr);
    gap: 0;
    max-width: 1400px;
    margin: 0 auto;
  }
  .collab-{{ section.id }}__item {
    position: relative;
    overflow: hidden;
    aspect-ratio: 3/4;
  }
  .collab-{{ section.id }}__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  .collab-{{ section.id }}__item:hover .collab-{{ section.id }}__img {
    transform: scale(1.04);
  }
  .collab-{{ section.id }}__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.05) 50%, transparent 100%);
    z-index: 1;
  }
  .collab-{{ section.id }}__text {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 2;
    padding: 2rem 2rem 2.5rem;
    color: #fff;
  }
  .collab-{{ section.id }}__item-eyebrow {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.7);
    display: block;
    margin-bottom: 0.5rem;
  }
  .collab-{{ section.id }}__item-heading {
    font-family: 'Instrument Sans', sans-serif;
    font-size: clamp(1rem, 2vw, 1.375rem);
    font-weight: 400;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #fff;
    margin: 0 0 1rem;
    line-height: 1.3;
  }
  .collab-{{ section.id }}__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #fff;
    text-decoration: none;
    border-bottom: 1px solid rgba(255,255,255,0.5);
    padding-bottom: 2px;
    transition: border-color 0.2s, gap 0.2s;
  }
  .collab-{{ section.id }}__link:hover { border-color: #fff; gap: 0.75rem; }
  .collab-{{ section.id }}__link svg { width: 12px; height: 12px; stroke: currentColor; fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; transition: transform 0.2s; }
  .collab-{{ section.id }}__link:hover svg { transform: translateX(3px); }
  @media (max-width: 767px) {
    .collab-{{ section.id }}__grid { grid-template-columns: 1fr; }
    .collab-{{ section.id }}__item { aspect-ratio: 4/5; }
  }
</style>

<section class="collab-{{ section.id }}">
  {%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
    <div class="collab-{{ section.id }}__header">
      {%- if section.settings.eyebrow != blank -%}
        <span class="collab-{{ section.id }}__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="collab-{{ section.id }}__title">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="collab-{{ section.id }}__grid">
    {%- for block in section.blocks -%}
      <div class="collab-{{ section.id }}__item" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          {{ block.settings.image | image_url: width: 900 | image_tag: class: 'collab-' | append: section.id | append: '__img', loading: 'lazy', alt: block.settings.heading | escape }}
        {%- else -%}
          <div style="width:100%;height:100%;background:linear-gradient(135deg,#2a2a2a,#1c1c1c);"></div>
        {%- endif -%}
        <div class="collab-{{ section.id }}__overlay" aria-hidden="true"></div>
        <div class="collab-{{ section.id }}__text">
          {%- if block.settings.eyebrow != blank -%}
            <span class="collab-{{ section.id }}__item-eyebrow">{{ block.settings.eyebrow }}</span>
          {%- endif -%}
          {%- if block.settings.heading != blank -%}
            <h3 class="collab-{{ section.id }}__item-heading">{{ block.settings.heading }}</h3>
          {%- endif -%}
          {%- if block.settings.link_label != blank -%}
            <a href="{{ block.settings.link_url | default: '#' }}" class="collab-{{ section.id }}__link">
              {{ block.settings.link_label }}
              <svg viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Collaboration",
  "tag": "section",
  "class": "section-collaboration",
  "max_blocks": 3,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 120, "step": 10, "default": 60, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 120, "step": 10, "default": 60, "unit": "px" }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Collaboration item",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
        { "type": "text", "id": "heading", "label": "Heading" },
        { "type": "text", "id": "link_label", "label": "Link label", "default": "Discover" },
        { "type": "url", "id": "link_url", "label": "Link URL" }
      ]
    }
  ],
  "presets": [{ "name": "Collaboration" }]
}
{% endschema %}
