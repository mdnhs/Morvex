{% comment %}
  Couple — full-width image with centered or left text overlay
{% endcomment %}

{%- liquid
  assign overlay = section.settings.overlay_opacity | default: 45
  assign overlay_alpha = overlay | times: 1.0 | divided_by: 100
  assign pos = section.settings.content_position | default: 'center'
  assign min_h = section.settings.min_height | default: 600
-%}

<style>
  .couple-{{ section.id }} {
    position: relative;
    min-height: {{ min_h }}px;
    display: flex;
    align-items: center;
    {% if pos == 'center' %}justify-content: center;{% else %}justify-content: flex-start;{% endif %}
    overflow: hidden;
    background: #1c1c1c;
  }
  .couple-{{ section.id }}__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .couple-{{ section.id }}__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,{{ overlay_alpha }});
    z-index: 1;
  }
  .couple-{{ section.id }}__content {
    position: relative;
    z-index: 2;
    color: #fff;
    padding: 5rem 2rem;
    max-width: 620px;
    {% if pos == 'center' %}
    text-align: center;
    margin: 0 auto;
    {% else %}
    margin-left: clamp(2rem, 8vw, 10rem);
    {% endif %}
  }
  .couple-{{ section.id }}__eyebrow {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.65);
    display: block;
    margin-bottom: 1rem;
  }
  .couple-{{ section.id }}__heading {
    font-family: 'Instrument Sans', sans-serif;
    font-size: clamp(2.25rem, 5vw, 4rem);
    font-weight: 300;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #fff;
    margin: 0 0 1.5rem;
    line-height: 1.1;
  }
  .couple-{{ section.id }}__text {
    font-family: 'Nunito', sans-serif;
    font-size: 1rem;
    color: rgba(255,255,255,0.82);
    line-height: 1.75;
    margin: 0 0 2rem;
    {% if pos == 'center' %}max-width: 480px; margin-left: auto; margin-right: auto;{% endif %}
  }
  .couple-{{ section.id }}__btn {
    display: inline-block;
    padding: 0.9rem 2.25rem;
    border: 1.5px solid rgba(255,255,255,0.7);
    color: #fff;
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.3s, border-color 0.3s;
  }
  .couple-{{ section.id }}__btn:hover { background: rgba(255,255,255,0.12); border-color: #fff; }
  @media (max-width: 767px) {
    .couple-{{ section.id }}__content { margin-left: 0; padding: 4rem 1.5rem; text-align: center; max-width: 100%; }
  }
</style>

<div class="couple-{{ section.id }}">
  {%- if section.settings.image != blank -%}
    {%- assign couple_img_class = 'couple-' | append: section.id | append: '__bg' -%}
    {%- assign couple_img_alt = section.settings.image.alt | default: section.settings.heading | escape -%}
    {{ section.settings.image | image_url: width: 1920 | image_tag: class: couple_img_class, loading: 'lazy', alt: couple_img_alt }}
  {%- else -%}
    <div style="position:absolute;inset:0;background:linear-gradient(135deg,#142e2b,#1c1c1c);"></div>
  {%- endif -%}

  <div class="couple-{{ section.id }}__overlay" aria-hidden="true"></div>

  <div class="couple-{{ section.id }}__content">
    {%- if section.settings.eyebrow != blank -%}
      <span class="couple-{{ section.id }}__eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="couple-{{ section.id }}__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.text != blank -%}
      <p class="couple-{{ section.id }}__text">{{ section.settings.text }}</p>
    {%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_link | default: '#' }}" class="couple-{{ section.id }}__btn">
        {{ section.settings.button_label }}
      </a>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Couple / Full Width Image",
  "tag": "section",
  "class": "section-couple",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Léo et Violette" },
    { "type": "textarea", "id": "text", "label": "Text" },
    { "type": "text", "id": "button_label", "label": "Button label" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity", "min": 0, "max": 80, "step": 5, "default": 45, "unit": "%" },
    { "type": "select", "id": "content_position", "label": "Content position", "options": [{"value":"center","label":"Center"},{"value":"left","label":"Left"}], "default": "center" },
    { "type": "range", "id": "min_height", "label": "Minimum height", "min": 400, "max": 900, "step": 50, "default": 600, "unit": "px" }
  ],
  "presets": [{ "name": "Couple / Full Width Image" }]
}
{% endschema %}
