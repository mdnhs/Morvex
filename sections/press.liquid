{% comment %}
  Press section — as seen in media, scrolling logos with featured quote.
{% endcomment %}

<section
  class="press-section section"
  id="section-press-{{ section.id }}"
  aria-label="{{ section.settings.heading | default: 'As seen in' | escape }}"
>
  <div class="container">

    {%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
      <div class="press-section__header fade-in">
        {%- if section.settings.eyebrow != blank -%}
          <p class="press-section__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="section-header__title" style="font-size:var(--text-xl);">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <!-- Logos -->
    {%- if section.blocks.size > 0 -%}
      <div class="press-logos fade-in">
        {%- for block in section.blocks -%}
          {%- if block.type == 'logo' -%}
            <div class="press-logos__item" {{ block.shopify_attributes }}>
              {%- if block.settings.image != blank -%}
                <a href="{{ block.settings.link | default: '#' }}" aria-label="{{ block.settings.name | escape }}">
                  <img
                    src="{{ block.settings.image | image_url: width: 200 }}"
                    alt="{{ block.settings.name | escape }}"
                    width="120"
                    loading="lazy"
                    style="filter:grayscale(1);opacity:0.55;transition:opacity 0.2s;max-height:40px;object-fit:contain;"
                    onmouseover="this.style.opacity='1'"
                    onmouseout="this.style.opacity='0.55'"
                  >
                </a>
              {%- else -%}
                <a href="{{ block.settings.link | default: '#' }}" class="press-logos__name">{{ block.settings.name }}</a>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <!-- Featured quote -->
      {%- for block in section.blocks -%}
        {%- if block.type == 'quote' -%}
          <div class="press-quote fade-in" {{ block.shopify_attributes }}>
            {%- if block.settings.quote != blank -%}
              <p class="press-quote__text">&ldquo;{{ block.settings.quote }}&rdquo;</p>
            {%- endif -%}
            {%- if block.settings.source != blank -%}
              <p class="press-quote__source">— {{ block.settings.source }}</p>
            {%- endif -%}
          </div>
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Press",
  "tag": "section",
  "class": "section-press",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "As Seen In"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Press Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo image"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Publication name",
          "default": "Vogue"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    },
    {
      "type": "quote",
      "name": "Featured Quote",
      "limit": 1,
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "A brand redefining modern luxury with an unwavering commitment to craft and sustainability."
        },
        {
          "type": "text",
          "id": "source",
          "label": "Source",
          "default": "Vogue Magazine"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Press",
      "blocks": [
        { "type": "logo", "settings": { "name": "Vogue" } },
        { "type": "logo", "settings": { "name": "Harper's Bazaar" } },
        { "type": "logo", "settings": { "name": "Elle" } },
        { "type": "logo", "settings": { "name": "WWD" } },
        { "type": "logo", "settings": { "name": "Forbes" } },
        { "type": "quote", "settings": { "quote": "A brand redefining modern luxury with an unwavering commitment to craft and sustainability.", "source": "Vogue Magazine" } }
      ]
    }
  ]
}
{% endschema %}
