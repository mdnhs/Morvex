{% comment %}
  Video section — poster image with play button overlay
{% endcomment %}

{%- liquid
  assign heading = section.settings.heading
  assign subtitle = section.settings.subtitle
  assign poster = section.settings.poster_image
  assign video_url = section.settings.video_url
  assign overlay = section.settings.overlay_opacity | default: 40
  assign overlay_alpha = overlay | times: 1.0 | divided_by: 100
  assign cta_label = section.settings.cta_label
  assign cta_link = section.settings.cta_link
  assign min_h = section.settings.min_height | default: 600
-%}

<style>
  .video-section-{{ section.id }} {
    position: relative;
    min-height: {{ min_h }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #1c1c1c;
    cursor: pointer;
  }
  .video-section-{{ section.id }}__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  .video-section-{{ section.id }}:hover .video-section-{{ section.id }}__bg {
    transform: scale(1.02);
  }
  .video-section-{{ section.id }}__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,{{ overlay_alpha }});
    z-index: 1;
  }
  .video-section-{{ section.id }}__content {
    position: relative;
    z-index: 2;
    text-align: center;
    color: #fff;
    padding: 3rem 2rem;
    max-width: 700px;
  }
  .video-section-{{ section.id }}__play {
    width: 80px;
    height: 80px;
    border: 2px solid rgba(255,255,255,0.8);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 2rem;
    transition: background 0.3s ease, transform 0.3s ease;
    cursor: pointer;
    background: none;
    color: #fff;
  }
  .video-section-{{ section.id }}__play:hover {
    background: rgba(255,255,255,0.15);
    transform: scale(1.08);
  }
  .video-section-{{ section.id }}__heading {
    font-family: 'Instrument Sans', sans-serif;
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #fff;
    margin: 0 0 1rem;
    line-height: 1.2;
  }
  .video-section-{{ section.id }}__subtitle {
    font-family: 'Nunito', sans-serif;
    font-size: 1rem;
    color: rgba(255,255,255,0.8);
    margin: 0 0 2rem;
    line-height: 1.6;
  }
  .video-section-{{ section.id }}__cta {
    display: inline-block;
    padding: 0.875rem 2rem;
    border: 1.5px solid rgba(255,255,255,0.7);
    color: #fff;
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.3s, border-color 0.3s;
  }
  .video-section-{{ section.id }}__cta:hover {
    background: rgba(255,255,255,0.12);
    border-color: #fff;
  }
  /* Modal overlay */
  .video-modal-{{ section.id }} {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.92);
    z-index: 9000;
    align-items: center;
    justify-content: center;
  }
  .video-modal-{{ section.id }}.open {
    display: flex;
  }
  .video-modal-{{ section.id }}__inner {
    position: relative;
    width: 90vw;
    max-width: 960px;
    aspect-ratio: 16/9;
  }
  .video-modal-{{ section.id }}__inner iframe,
  .video-modal-{{ section.id }}__inner video {
    width: 100%;
    height: 100%;
    border: none;
  }
  .video-modal-{{ section.id }}__close {
    position: absolute;
    top: -40px;
    right: 0;
    background: none;
    border: none;
    color: #fff;
    font-size: 1.5rem;
    cursor: pointer;
    line-height: 1;
  }
</style>

<div
  class="video-section-{{ section.id }}"
  id="video-section-{{ section.id }}"
  role="region"
  aria-label="{{ heading | escape }}"
>
  {%- if poster != blank -%}
    <img
      class="video-section-{{ section.id }}__bg"
      src="{{ poster | image_url: width: 1920 }}"
      alt="{{ poster.alt | default: heading | escape }}"
      loading="lazy"
      width="1920"
    >
  {%- else -%}
    <div style="position:absolute;inset:0;background:linear-gradient(135deg,#142e2b,#1c1c1c);"></div>
  {%- endif -%}

  <div class="video-section-{{ section.id }}__overlay"></div>

  <div class="video-section-{{ section.id }}__content">
    {%- if video_url != blank -%}
      <button
        class="video-section-{{ section.id }}__play"
        aria-label="Play video"
        data-video-play-{{ section.id }}
        type="button"
      >
        <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <polygon points="5 3 19 12 5 21 5 3"/>
        </svg>
      </button>
    {%- endif -%}

    {%- if heading != blank -%}
      <h2 class="video-section-{{ section.id }}__heading">{{ heading }}</h2>
    {%- endif -%}

    {%- if subtitle != blank -%}
      <p class="video-section-{{ section.id }}__subtitle">{{ subtitle }}</p>
    {%- endif -%}

    {%- if cta_label != blank -%}
      <a
        href="{{ cta_link | default: routes.all_products_collection_url }}"
        class="video-section-{{ section.id }}__cta"
      >
        {{ cta_label }}
      </a>
    {%- endif -%}
  </div>
</div>

{%- if video_url != blank -%}
  <div class="video-modal-{{ section.id }}" id="video-modal-{{ section.id }}" role="dialog" aria-modal="true" aria-label="Video player">
    <div class="video-modal-{{ section.id }}__inner">
      <button class="video-modal-{{ section.id }}__close" aria-label="Close video" data-video-close-{{ section.id }} type="button">&times;</button>
    </div>
  </div>

  <script>
  (function(){
    var playBtn = document.querySelector('[data-video-play-{{ section.id }}]');
    var modal = document.getElementById('video-modal-{{ section.id }}');
    var inner = modal ? modal.querySelector('.video-modal-{{ section.id }}__inner') : null;
    var closeBtn = document.querySelector('[data-video-close-{{ section.id }}]');
    var videoUrl = {{ section.settings.video_url | json }};

    function getEmbedUrl(url) {
      var yt = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([^&\s]+)/);
      if (yt) return 'https://www.youtube.com/embed/' + yt[1] + '?autoplay=1&rel=0';
      var vm = url.match(/vimeo\.com\/(\d+)/);
      if (vm) return 'https://player.vimeo.com/video/' + vm[1] + '?autoplay=1';
      return url;
    }

    function openModal() {
      if (!modal || !inner) return;
      var embedUrl = getEmbedUrl(videoUrl);
      var iframe = document.createElement('iframe');
      iframe.src = embedUrl;
      iframe.allow = 'autoplay; fullscreen';
      iframe.allowFullscreen = true;
      inner.appendChild(iframe);
      modal.classList.add('open');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      if (!modal) return;
      modal.classList.remove('open');
      var iframe = inner ? inner.querySelector('iframe') : null;
      if (iframe) iframe.remove();
      document.body.style.overflow = '';
    }

    if (playBtn) playBtn.addEventListener('click', openModal);
    if (closeBtn) closeBtn.addEventListener('click', closeModal);
    if (modal) modal.addEventListener('click', function(e){ if (e.target === modal) closeModal(); });
    document.addEventListener('keydown', function(e){ if (e.key === 'Escape') closeModal(); });
  })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Video",
  "tag": "section",
  "class": "section-video",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Made in Italy — Finest handmade"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Each piece is crafted by master artisans."
    },
    {
      "type": "image_picker",
      "id": "poster_image",
      "label": "Poster image"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Video URL",
      "info": "YouTube or Vimeo URL"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0, "max": 80, "step": 5, "default": 40, "unit": "%"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Minimum height",
      "min": 400, "max": 900, "step": 50, "default": 600, "unit": "px"
    }
  ],
  "presets": [{ "name": "Video" }]
}
{% endschema %}
