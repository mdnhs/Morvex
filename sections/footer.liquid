{% comment %}
  Footer section — dark background, 4-column layout.
  Brand column, Navigation, Customer Service, Newsletter signup.
{% endcomment %}

<footer class="site-footer" role="contentinfo">
  <div class="container">

    <!-- Footer Top: 4 columns -->
    <div class="footer__top">

      <!-- Column 1: Brand -->
      <div class="footer__brand">
        <a href="{{ routes.root_url }}" class="footer__brand-logo">
          {%- if section.settings.footer_logo != blank -%}
            <img
              src="{{ section.settings.footer_logo | image_url: width: 180 }}"
              alt="{{ shop.name | escape }}"
              width="180"
              loading="lazy"
              style="filter:brightness(0) invert(1);"
            >
          {%- else -%}
            {{ shop.name }}
          {%- endif -%}
        </a>
        <p class="footer__brand-tagline">
          {{ section.settings.footer_tagline | default: 'Luxury redefined. Timeless pieces crafted for the discerning individual.' }}
        </p>

        <!-- Social Links -->
        <div class="footer__social">
          {%- if section.settings.instagram_url != blank -%}
            <a
              href="{{ section.settings.instagram_url }}"
              class="footer__social-link"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Instagram"
            >
              {%- render 'icon', icon: 'instagram', size: 18 -%}
            </a>
          {%- endif -%}
          {%- if section.settings.facebook_url != blank -%}
            <a
              href="{{ section.settings.facebook_url }}"
              class="footer__social-link"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Facebook"
            >
              {%- render 'icon', icon: 'facebook', size: 18 -%}
            </a>
          {%- endif -%}
          {%- if section.settings.tiktok_url != blank -%}
            <a
              href="{{ section.settings.tiktok_url }}"
              class="footer__social-link"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="TikTok"
            >
              {%- render 'icon', icon: 'tiktok', size: 18 -%}
            </a>
          {%- endif -%}
          {%- if section.settings.pinterest_url != blank -%}
            <a
              href="{{ section.settings.pinterest_url }}"
              class="footer__social-link"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Pinterest"
            >
              {%- render 'icon', icon: 'pinterest', size: 18 -%}
            </a>
          {%- endif -%}
        </div>
      </div>

      <!-- Column 2: Navigation -->
      <div class="footer__nav-col">
        <h3 class="footer__nav-title">{{ 'footer.navigation' | t | default: 'Explore' }}</h3>
        {%- if section.settings.footer_menu != blank -%}
          <ul class="footer__nav-list" role="list">
            {%- for link in linklists[section.settings.footer_menu].links -%}
              <li role="listitem">
                <a href="{{ link.url }}" class="footer__nav-link">{{ link.title }}</a>
              </li>
            {%- endfor -%}
          </ul>
        {%- else -%}
          <ul class="footer__nav-list" role="list">
            <li><a href="{{ routes.root_url }}" class="footer__nav-link">Home</a></li>
            <li><a href="{{ routes.collections_url }}" class="footer__nav-link">Collections</a></li>
            <li><a href="/pages/about" class="footer__nav-link">About</a></li>
            <li><a href="/blogs/journal" class="footer__nav-link">Journal</a></li>
          </ul>
        {%- endif -%}
      </div>

      <!-- Column 3: Customer Service -->
      <div class="footer__nav-col">
        <h3 class="footer__nav-title">{{ 'footer.customer_service' | t | default: 'Customer Care' }}</h3>
        {%- if section.settings.service_menu != blank -%}
          <ul class="footer__nav-list" role="list">
            {%- for link in linklists[section.settings.service_menu].links -%}
              <li role="listitem">
                <a href="{{ link.url }}" class="footer__nav-link">{{ link.title }}</a>
              </li>
            {%- endfor -%}
          </ul>
        {%- else -%}
          <ul class="footer__nav-list" role="list">
            <li><a href="/pages/contact" class="footer__nav-link">{{ 'footer.contact_us' | t | default: 'Contact Us' }}</a></li>
            <li><a href="/pages/faq" class="footer__nav-link">{{ 'footer.faq' | t | default: 'FAQ' }}</a></li>
            <li><a href="/pages/shipping" class="footer__nav-link">{{ 'footer.shipping' | t | default: 'Shipping & Delivery' }}</a></li>
            <li><a href="/pages/returns" class="footer__nav-link">{{ 'footer.returns' | t | default: 'Returns & Exchanges' }}</a></li>
            <li><a href="/pages/size-guide" class="footer__nav-link">{{ 'footer.size_guide' | t | default: 'Size Guide' }}</a></li>
          </ul>
        {%- endif -%}
      </div>

      <!-- Column 4: Newsletter -->
      {%- if section.settings.show_newsletter -%}
        <div class="footer__newsletter-col">
          <h3 class="footer__nav-title">{{ section.settings.newsletter_heading | default: 'Stay in the know' }}</h3>
          <p class="footer__newsletter-text">
            {{ section.settings.newsletter_subtext | default: 'Subscribe for exclusive access to new arrivals, private sales, and editorial content.' }}
          </p>
          {%- form 'customer', id: 'footer-newsletter-form' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="footer__newsletter-form">
              <input
                type="email"
                class="footer__newsletter-input"
                name="contact[email]"
                id="footer-newsletter-email"
                placeholder="{{ 'newsletter.email_placeholder' | t | default: 'Your email address' }}"
                required
                autocomplete="email"
                aria-label="{{ 'newsletter.email_label' | t | default: 'Email address' }}"
              >
              <button type="submit" class="footer__newsletter-btn">
                {{ section.settings.newsletter_button_label | default: 'Subscribe' }}
              </button>
            </div>
            {%- if form.posted_successfully? -%}
              <p style="color:var(--color-accent);font-size:0.875rem;margin-top:0.75rem;">
                {{ 'newsletter.success' | t | default: 'Thank you for subscribing!' }}
              </p>
            {%- endif -%}
          {%- endform -%}
        </div>
      {%- endif -%}

    </div><!-- /footer__top -->

    <!-- Footer Bottom -->
    <div class="footer__bottom">
      <p class="footer__copyright">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ 'footer.copyright' | t | default: 'All rights reserved.' }}
      </p>

      <div class="footer__legal">
        <a href="{{ shop.privacy_policy.url }}" class="footer__legal-link">
          {{ 'footer.privacy_policy' | t | default: 'Privacy Policy' }}
        </a>
        <a href="{{ shop.terms_of_service.url }}" class="footer__legal-link">
          {{ 'footer.terms' | t | default: 'Terms of Service' }}
        </a>
        <a href="{{ shop.refund_policy.url }}" class="footer__legal-link">
          {{ 'footer.refunds' | t | default: 'Refund Policy' }}
        </a>
      </div>

      <!-- Payment Icons -->
      <div class="footer__payments" aria-label="{{ 'footer.payment_methods' | t | default: 'Payment methods' }}">
        {%- for type in shop.enabled_payment_types -%}
          {{ type | payment_type_svg_tag: class: 'footer__payment-icon' }}
        {%- endfor -%}
      </div>
    </div>

  </div><!-- /container -->
</footer>

{% schema %}
{
  "name": "Footer",
  "class": "section-footer",
  "settings": [
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "image_picker",
      "id": "footer_logo",
      "label": "Footer logo"
    },
    {
      "type": "text",
      "id": "footer_tagline",
      "default": "Luxury redefined. Timeless pieces crafted for the discerning individual.",
      "label": "Brand tagline"
    },
    {
      "type": "header",
      "content": "Navigation menus"
    },
    {
      "type": "link_list",
      "id": "footer_menu",
      "label": "Navigation menu",
      "default": "footer"
    },
    {
      "type": "link_list",
      "id": "service_menu",
      "label": "Customer service menu"
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "default": true,
      "label": "Show newsletter signup"
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "default": "Stay in the know",
      "label": "Newsletter heading"
    },
    {
      "type": "text",
      "id": "newsletter_subtext",
      "default": "Subscribe for exclusive access to new arrivals, private sales, and editorial content.",
      "label": "Newsletter subtext"
    },
    {
      "type": "text",
      "id": "newsletter_button_label",
      "default": "Subscribe",
      "label": "Subscribe button label"
    },
    {
      "type": "header",
      "content": "Social media"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "TikTok URL"
    },
    {
      "type": "url",
      "id": "pinterest_url",
      "label": "Pinterest URL"
    }
  ]
}
{% endschema %}
