{% comment %}
  Content Over Media — background image with text overlay
{% endcomment %}

{%- liquid
  assign overlay = section.settings.overlay_opacity | default: 40
  assign overlay_alpha = overlay | times: 1.0 | divided_by: 100
  assign pos = section.settings.content_position | default: 'left'
  assign min_h = section.settings.min_height | default: 600
-%}

<style>
  .com-{{ section.id }} {
    position: relative;
    min-height: {{ min_h }}px;
    display: flex;
    align-items: center;
    {% if pos == 'center' %}justify-content: center;{% else %}justify-content: flex-start;{% endif %}
    overflow: hidden;
    background: #1c1c1c;
  }
  .com-{{ section.id }}__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .com-{{ section.id }}__overlay {
    position: absolute;
    inset: 0;
    {% if pos == 'left' %}
    background: linear-gradient(to right, rgba(0,0,0,{{ overlay_alpha | plus: 0.15 }}) 0%, rgba(0,0,0,{{ overlay_alpha }}) 50%, rgba(0,0,0,{{ overlay_alpha | times: 0.4 }}) 100%);
    {% else %}
    background: rgba(0,0,0,{{ overlay_alpha }});
    {% endif %}
    z-index: 1;
  }
  .com-{{ section.id }}__content {
    position: relative;
    z-index: 2;
    color: #fff;
    padding: 5rem 2rem;
    max-width: 560px;
    {% if pos == 'left' %}
    margin-left: clamp(1.5rem, 6vw, 7rem);
    {% else %}
    margin: 0 auto;
    text-align: center;
    {% endif %}
  }
  .com-{{ section.id }}__eyebrow {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.65);
    margin-bottom: 1.25rem;
    display: block;
  }
  .com-{{ section.id }}__heading {
    font-family: 'Instrument Sans', sans-serif;
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    line-height: 1.1;
    color: #fff;
    margin: 0 0 1.25rem;
  }
  .com-{{ section.id }}__desc {
    font-family: 'Nunito', sans-serif;
    font-size: 1rem;
    color: rgba(255,255,255,0.8);
    line-height: 1.7;
    margin: 0 0 2rem;
    {% if pos == 'center' %}max-width: 480px; margin-left: auto; margin-right: auto;{% endif %}
  }
  .com-{{ section.id }}__links {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
    {% if pos == 'center' %}justify-content: center;{% endif %}
  }
  .com-{{ section.id }}__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #fff;
    text-decoration: none;
    border-bottom: 1px solid rgba(255,255,255,0.45);
    padding-bottom: 2px;
    transition: border-color 0.2s, gap 0.2s;
  }
  .com-{{ section.id }}__link:hover { border-color: #fff; gap: 0.75rem; }
  .com-{{ section.id }}__arrow { display: inline-flex; align-items: center; transition: transform 0.2s; }
  .com-{{ section.id }}__link:hover .com-{{ section.id }}__arrow { transform: translateX(3px); }
  .com-{{ section.id }}__arrow svg { width: 14px; height: 14px; stroke: currentColor; fill: none; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; }
  @media (max-width: 749px) {
    .com-{{ section.id }}__content { margin-left: 0; padding: 3.5rem 1.5rem; text-align: center; max-width: 100%; }
    .com-{{ section.id }}__links { justify-content: center; }
  }
</style>

<div class="com-{{ section.id }}">
  {%- if section.settings.image != blank -%}
    {%- assign com_img_class = 'com-' | append: section.id | append: '__bg' -%}
    {%- assign com_img_alt = section.settings.image.alt | default: section.settings.heading | escape -%}
    {{ section.settings.image | image_url: width: 1920 | image_tag: class: com_img_class, loading: 'lazy', alt: com_img_alt }}
  {%- else -%}
    <div style="position:absolute;inset:0;background:linear-gradient(135deg,#142e2b,#1c1c1c);"></div>
  {%- endif -%}

  <div class="com-{{ section.id }}__overlay" aria-hidden="true"></div>

  <div class="com-{{ section.id }}__content">
    {%- if section.settings.eyebrow != blank -%}
      <span class="com-{{ section.id }}__eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="com-{{ section.id }}__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.description != blank -%}
      <p class="com-{{ section.id }}__desc">{{ section.settings.description }}</p>
    {%- endif -%}
    {%- liquid
      assign has_l1 = false
      assign has_l2 = false
      if section.settings.link_1_label != blank and section.settings.link_1_url != blank
        assign has_l1 = true
      endif
      if section.settings.link_2_label != blank and section.settings.link_2_url != blank
        assign has_l2 = true
      endif
    -%}
    {%- if has_l1 or has_l2 -%}
      <div class="com-{{ section.id }}__links">
        {%- if has_l1 -%}
          <a href="{{ section.settings.link_1_url }}" class="com-{{ section.id }}__link">
            {{ section.settings.link_1_label }}
            <span class="com-{{ section.id }}__arrow" aria-hidden="true"><svg viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>
          </a>
        {%- endif -%}
        {%- if has_l2 -%}
          <a href="{{ section.settings.link_2_url }}" class="com-{{ section.id }}__link">
            {{ section.settings.link_2_label }}
            <span class="com-{{ section.id }}__arrow" aria-hidden="true"><svg viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Content over Media",
  "tag": "section",
  "class": "section-content-over-media",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "New Arrival" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Le Backpack" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Structured silhouette, buttery-soft full-grain leather." },
    { "type": "header", "content": "Links" },
    { "type": "text", "id": "link_1_label", "label": "Link 1 label" },
    { "type": "url", "id": "link_1_url", "label": "Link 1 URL" },
    { "type": "text", "id": "link_2_label", "label": "Link 2 label" },
    { "type": "url", "id": "link_2_url", "label": "Link 2 URL" },
    { "type": "header", "content": "Media" },
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity", "min": 0, "max": 80, "step": 5, "default": 40, "unit": "%" },
    { "type": "header", "content": "Layout" },
    { "type": "select", "id": "content_position", "label": "Content position", "options": [{"value":"left","label":"Left"},{"value":"center","label":"Center"}], "default": "left" },
    { "type": "range", "id": "min_height", "label": "Minimum height", "min": 400, "max": 800, "step": 40, "default": 600, "unit": "px" }
  ],
  "presets": [{ "name": "Content over Media" }]
}
{% endschema %}
