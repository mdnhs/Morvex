{% comment %}
  Collection Grid section — 2 or 3 collection images with overlay text.
{% endcomment %}

<section
  class="section"
  id="section-collection-grid-{{ section.id }}"
  style="padding-top:0;padding-bottom:0;"
  aria-label="{{ section.settings.title | default: 'Collections' | escape }}"
>

  {%- if section.settings.title != blank or section.settings.eyebrow != blank -%}
    <div class="container" style="padding-top:var(--space-16);padding-bottom:var(--space-8);text-align:center;">
      {%- if section.settings.eyebrow != blank -%}
        <p class="section-header__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="section-header__title">{{ section.settings.title }}</h2>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    <div class="collection-grid{% if section.blocks.size >= 3 %} collection-grid--3{% endif %}">
      {%- for block in section.blocks -%}
        <a
          href="{{ block.settings.link | default: routes.collections_url }}"
          class="collection-grid__item"
          {{ block.shopify_attributes }}
          aria-label="{{ block.settings.title | escape }}"
        >
          {%- if block.settings.image != blank -%}
            <img
              src="{{ block.settings.image | image_url: width: 900 }}"
              srcset="{{ block.settings.image | image_url: width: 600 }} 600w, {{ block.settings.image | image_url: width: 900 }} 900w, {{ block.settings.image | image_url: width: 1200 }} 1200w"
              sizes="(max-width:749px) 100vw, {% if section.blocks.size >= 3 %}33vw{% else %}50vw{% endif %}"
              alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
              loading="lazy"
            >
          {%- else -%}
            <div style="width:100%;height:100%;background:var(--color-surface);"></div>
          {%- endif -%}
          <div class="collection-grid__overlay" aria-hidden="true"></div>
          <div class="collection-grid__content">
            {%- if block.settings.label != blank -%}
              <p class="collection-grid__label">{{ block.settings.label }}</p>
            {%- endif -%}
            {%- if block.settings.title != blank -%}
              <h3 class="collection-grid__title">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.link_text != blank -%}
              <span class="collection-grid__link">{{ block.settings.link_text }}</span>
            {%- endif -%}
          </div>
        </a>
      {%- endfor -%}
    </div>
  {%- endif -%}

</section>

{% schema %}
{
  "name": "Collection Grid",
  "tag": "section",
  "class": "section-collection-grid",
  "max_blocks": 3,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label (small text above title)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Women"
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "Link text",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Grid",
      "blocks": [
        {
          "type": "collection",
          "settings": { "title": "Women", "link_text": "Shop Now", "label": "New Season" }
        },
        {
          "type": "collection",
          "settings": { "title": "Men", "link_text": "Shop Now", "label": "New Season" }
        }
      ]
    }
  ]
}
{% endschema %}
