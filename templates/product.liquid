{% comment %}
  Product page template — full product detail with gallery, variants, and accordion.
{% endcomment %}

{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign featured_media = current_variant.featured_media | default: product.featured_media -%}

<!-- Product JSON for JavaScript variant selection -->
<script id="product-json" type="application/json">
  {{ product | json }}
</script>

<div class="product-page">
  <div class="container">

    <!-- Breadcrumb -->
    <nav class="product-page__breadcrumb" aria-label="{{ 'general.breadcrumbs.title' | t | default: 'Breadcrumb' }}">
      <a href="{{ routes.root_url }}">{{ 'general.breadcrumbs.home' | t | default: 'Home' }}</a>
      {%- render 'icon', icon: 'chevron-right', size: 12 -%}
      {%- if collection -%}
        <a href="{{ collection.url }}">{{ collection.title }}</a>
        {%- render 'icon', icon: 'chevron-right', size: 12 -%}
      {%- endif -%}
      <span aria-current="page">{{ product.title }}</span>
    </nav>

    <!-- Product Layout -->
    <div class="product-page__inner">

      <!-- LEFT: Image Gallery -->
      <div class="product-gallery fade-in-left">

        <!-- Main Image -->
        <div class="product-gallery__main" id="product-main-image">
          {%- if featured_media -%}
            <img
              class="product-gallery__main-img"
              id="product-featured-image"
              src="{{ featured_media | image_url: width: 900 }}"
              alt="{{ featured_media.alt | default: product.title | escape }}"
              width="{{ featured_media.width }}"
              height="{{ featured_media.height }}"
              loading="eager"
              fetchpriority="high"
            >
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag: 'product-gallery__main-img' }}
          {%- endif -%}
        </div>

        <!-- Thumbnail Grid -->
        {%- if product.media.size > 1 -%}
          <div class="product-gallery__thumbs" role="list">
            {%- for media in product.media -%}
              <button
                class="product-gallery__thumb{% if forloop.first %} active{% endif %}"
                type="button"
                data-src="{{ media | image_url: width: 900 }}"
                aria-label="{{ 'products.product.load_image' | t | default: 'View image' }} {{ forloop.index }} of {{ product.media.size }}"
                role="listitem"
              >
                <img
                  src="{{ media | image_url: width: 150 }}"
                  alt="{{ media.alt | default: product.title | escape }}"
                  loading="lazy"
                  width="150"
                  height="{{ 150 | divided_by: media.aspect_ratio | round }}"
                >
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}

      </div>

      <!-- RIGHT: Product Info -->
      <div class="product-info fade-in-right">

        <!-- Vendor -->
        {%- if product.vendor != blank -%}
          <p class="product-info__vendor">{{ product.vendor }}</p>
        {%- endif -%}

        <!-- Title -->
        <h1 class="product-info__title">{{ product.title }}</h1>

        <!-- Price -->
        <div class="product-info__price" id="product-price">
          {%- if current_variant.compare_at_price > current_variant.price -%}
            <span class="product-info__price-current product-info__price-current--sale">
              {{ current_variant.price | money }}
            </span>
            <span class="product-info__price-compare">
              {{ current_variant.compare_at_price | money }}
            </span>
            <span class="product-info__price-savings">
              Save {{ current_variant.compare_at_price | minus: current_variant.price | money }}
            </span>
          {%- else -%}
            <span class="product-info__price-current">
              {{ current_variant.price | money }}
            </span>
          {%- endif -%}
        </div>

        <!-- Add to Cart Form -->
        <form action="{{ routes.cart_add_url }}" method="post" id="product-form">
          <input type="hidden" name="id" value="{{ current_variant.id }}">

          <!-- Variant Selectors -->
          {%- unless product.has_only_default_variant -%}
            <div class="product-variants">
              {%- for option in product.options_with_values -%}
                <div class="variant-group">
                  <p class="variant-group__label">
                    {{ option.name }}:
                    <span id="variant-label-{{ option.position }}">{{ option.selected_value }}</span>
                  </p>
                  <div class="variant-options">
                    {%- if option.name == 'Color' or option.name == 'Colour' -%}
                      {%- for value in option.values -%}
                        {%- assign swatch_bg = value | handleize -%}
                        <button
                          type="button"
                          class="variant-option-swatch{% if option.selected_value == value %} active{% endif %}"
                          style="background-color: {{ swatch_bg }};"
                          data-option-index="{{ option.position }}"
                          data-value="{{ value | escape }}"
                          title="{{ value | escape }}"
                          aria-label="{{ value | escape }}"
                          aria-pressed="{{ option.selected_value == value }}"
                        ></button>
                      {%- endfor -%}
                    {%- else -%}
                      {%- for value in option.values -%}
                        {%- assign is_available = false -%}
                        {%- for variant in product.variants -%}
                          {%- if variant.available -%}
                            {%- if option.position == 1 and variant.option1 == value -%}
                              {%- assign is_available = true -%}
                            {%- elsif option.position == 2 and variant.option2 == value -%}
                              {%- assign is_available = true -%}
                            {%- elsif option.position == 3 and variant.option3 == value -%}
                              {%- assign is_available = true -%}
                            {%- endif -%}
                          {%- endif -%}
                        {%- endfor -%}
                        <button
                          type="button"
                          class="variant-option-btn{% if option.selected_value == value %} active{% endif %}{% unless is_available %} sold-out{% endunless %}"
                          data-option-index="{{ option.position }}"
                          data-value="{{ value | escape }}"
                          aria-pressed="{{ option.selected_value == value }}"
                          {% unless is_available %}aria-label="{{ value | escape }} — {{ 'products.product.sold_out' | t }}"{% endunless %}
                        >
                          {{ value }}
                        </button>
                      {%- endfor -%}
                    {%- endif -%}
                  </div>
                </div>
              {%- endfor -%}
            </div>
          {%- endunless -%}

          <!-- Quantity -->
          <div class="product-quantity">
            <label class="product-quantity__label" for="product-quantity">
              {{ 'products.product.quantity' | t | default: 'Quantity' }}
            </label>
            <div class="quantity-selector">
              <button
                type="button"
                class="quantity-selector__btn"
                data-qty-minus
                aria-label="{{ 'products.product.decrease_quantity' | t | default: 'Decrease quantity' }}"
              >−</button>
              <input
                type="number"
                class="quantity-selector__input"
                name="quantity"
                id="product-quantity"
                value="1"
                min="1"
                {%- if current_variant.inventory_management == 'shopify' and current_variant.inventory_policy == 'deny' -%}
                  max="{{ current_variant.inventory_quantity }}"
                {%- endif -%}
                aria-label="{{ 'products.product.quantity' | t | default: 'Quantity' }}"
              >
              <button
                type="button"
                class="quantity-selector__btn"
                data-qty-plus
                aria-label="{{ 'products.product.increase_quantity' | t | default: 'Increase quantity' }}"
              >+</button>
            </div>
          </div>

          <!-- Actions -->
          <div class="product-actions">
            <button
              type="submit"
              class="btn btn--primary btn--add-to-cart"
              id="product-add-to-cart"
              data-add-text="{{ 'products.product.add_to_cart' | t | default: 'Add to Cart' }}"
              data-sold-out-text="{{ 'products.product.sold_out' | t | default: 'Sold Out' }}"
              {%- unless current_variant.available -%}disabled{%- endunless -%}
            >
              {%- if current_variant.available -%}
                {{ 'products.product.add_to_cart' | t | default: 'Add to Cart' }}
              {%- else -%}
                {{ 'products.product.sold_out' | t | default: 'Sold Out' }}
              {%- endif -%}
            </button>
          </div>

        </form>

        <!-- Trust Badges -->
        <div style="display:flex;gap:var(--space-8);padding:var(--space-5) 0;border-top:1px solid var(--color-border);border-bottom:1px solid var(--color-border);margin-bottom:var(--space-6);">
          <div style="display:flex;align-items:center;gap:var(--space-2);font-size:var(--text-xs);color:var(--color-text-light);">
            {%- render 'icon', icon: 'truck', size: 16 -%}
            Free Shipping
          </div>
          <div style="display:flex;align-items:center;gap:var(--space-2);font-size:var(--text-xs);color:var(--color-text-light);">
            {%- render 'icon', icon: 'refresh', size: 16 -%}
            Free Returns
          </div>
          <div style="display:flex;align-items:center;gap:var(--space-2);font-size:var(--text-xs);color:var(--color-text-light);">
            {%- render 'icon', icon: 'lock', size: 16 -%}
            Secure Checkout
          </div>
        </div>

        <!-- Accordion sections -->
        <div class="product-accordion accordion" data-single-open="true">

          <!-- Description -->
          {%- if product.description != blank -%}
            <div class="accordion-item open">
              <button
                class="accordion-header"
                type="button"
                aria-expanded="true"
                aria-controls="accordion-description"
              >
                {{ 'products.product.description' | t | default: 'Product Details' }}
                {%- render 'icon', icon: 'chevron-down', size: 16, class: 'accordion-icon' -%}
              </button>
              <div class="accordion-body richtext" id="accordion-description">
                {{ product.description }}
              </div>
            </div>
          {%- endif -%}

          <!-- Sizing -->
          <div class="accordion-item">
            <button
              class="accordion-header"
              type="button"
              aria-expanded="false"
              aria-controls="accordion-sizing"
            >
              {{ 'products.product.size_guide' | t | default: 'Size & Fit' }}
              {%- render 'icon', icon: 'chevron-down', size: 16, class: 'accordion-icon' -%}
            </button>
            <div class="accordion-body" id="accordion-sizing">
              <p>This piece is designed with a relaxed, elevated fit. We recommend sizing up if you prefer a more oversized silhouette. Our model is 178cm and wears a size Small.</p>
              <ul style="list-style:disc;padding-left:1.25rem;margin-top:0.75rem;">
                <li>XS: Chest 81–86cm, Waist 61–66cm</li>
                <li>S: Chest 86–91cm, Waist 66–71cm</li>
                <li>M: Chest 91–97cm, Waist 71–76cm</li>
                <li>L: Chest 97–102cm, Waist 76–81cm</li>
                <li>XL: Chest 107–112cm, Waist 86–91cm</li>
              </ul>
            </div>
          </div>

          <!-- Materials -->
          <div class="accordion-item">
            <button
              class="accordion-header"
              type="button"
              aria-expanded="false"
              aria-controls="accordion-materials"
            >
              {{ 'products.product.materials' | t | default: 'Materials & Care' }}
              {%- render 'icon', icon: 'chevron-down', size: 16, class: 'accordion-icon' -%}
            </button>
            <div class="accordion-body" id="accordion-materials">
              <p>Crafted from the finest sustainably sourced materials. Each piece is finished by hand for maximum quality.</p>
              <ul style="list-style:disc;padding-left:1.25rem;margin-top:0.75rem;">
                <li>Dry clean or gentle hand wash in cold water</li>
                <li>Lay flat to dry</li>
                <li>Do not bleach</li>
                <li>Cool iron if needed, inside out</li>
              </ul>
            </div>
          </div>

          <!-- Shipping -->
          <div class="accordion-item">
            <button
              class="accordion-header"
              type="button"
              aria-expanded="false"
              aria-controls="accordion-shipping"
            >
              {{ 'products.product.shipping' | t | default: 'Shipping & Returns' }}
              {%- render 'icon', icon: 'chevron-down', size: 16, class: 'accordion-icon' -%}
            </button>
            <div class="accordion-body" id="accordion-shipping">
              <ul style="list-style:none;display:flex;flex-direction:column;gap:0.75rem;">
                <li style="display:flex;align-items:flex-start;gap:0.75rem;">
                  {%- render 'icon', icon: 'truck', size: 16 -%}
                  <span><strong>Free standard shipping</strong> on orders over $150. Arrives in 3–5 business days.</span>
                </li>
                <li style="display:flex;align-items:flex-start;gap:0.75rem;">
                  {%- render 'icon', icon: 'refresh', size: 16 -%}
                  <span><strong>Free returns</strong> within 30 days of delivery.</span>
                </li>
                <li style="display:flex;align-items:flex-start;gap:0.75rem;">
                  {%- render 'icon', icon: 'lock', size: 16 -%}
                  <span>All orders are securely packaged and fully insured.</span>
                </li>
              </ul>
            </div>
          </div>

        </div><!-- /accordion -->

      </div><!-- /product-info -->

    </div><!-- /product-page__inner -->

  </div>
</div>
