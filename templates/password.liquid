<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ shop.name }} — Coming Soon</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600&family=Nunito:wght@300;400;500&display=swap" rel="stylesheet">
  {{ content_for_header }}
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      min-height: 100vh; display: flex; align-items: center; justify-content: center;
      background: #1c1c1c; color: #fff; font-family: 'Nunito', sans-serif;
    }
    .password-page { text-align: center; padding: 2rem; max-width: 480px; }
    .password-page__logo {
      font-family: 'Instrument Sans', sans-serif; font-size: 1.75rem; font-weight: 600;
      letter-spacing: 4px; text-transform: uppercase; margin-bottom: 2rem;
    }
    .password-page__heading {
      font-family: 'Instrument Sans', sans-serif; font-size: 1.25rem; font-weight: 400;
      letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 1rem;
    }
    .password-page__text {
      font-size: 0.95rem; color: rgba(255,255,255,0.7); line-height: 1.7; margin-bottom: 2rem;
    }
    .password-page form { display: flex; gap: 0; }
    .password-page input[type="password"] {
      flex: 1; padding: 14px 20px; font-family: 'Nunito', sans-serif; font-size: 0.9rem;
      border: 1px solid rgba(255,255,255,0.3); border-right: none; background: transparent;
      color: #fff; outline: none;
    }
    .password-page input::placeholder { color: rgba(255,255,255,0.4); }
    .password-page button {
      padding: 14px 28px; background: #fff; color: #1c1c1c; font-family: 'Nunito', sans-serif;
      font-size: 11px; font-weight: 500; letter-spacing: 3px; text-transform: uppercase;
      border: 1px solid #fff; cursor: pointer;
    }
  </style>
</head>
<body>
  <div class="password-page">
    <div class="password-page__logo">{{ shop.name }}</div>
    <h1 class="password-page__heading">Opening Soon</h1>
    <p class="password-page__text">We are currently working on our store. Please check back soon.</p>
    {%- form 'storefront_password' -%}
      <input type="password" name="password" placeholder="Enter store password">
      <button type="submit">Enter</button>
    {%- endform -%}
  </div>
</body>
</html>
