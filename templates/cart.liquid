{% comment %}
  Cart page template — table view with quantity controls and order summary.
{% endcomment %}

<div class="cart-page">
  <div class="container">

    <h1 class="cart-page__title fade-in">{{ 'general.cart.title' | t }}</h1>

    {%- if cart.item_count > 0 -%}

      <form action="{{ routes.cart_url }}" method="post" data-cart-form>

        <div class="cart-layout">

          <!-- Cart Items Table -->
          <div>
            <table class="cart-table" aria-label="{{ 'general.cart.items_in_cart' | t | default: 'Your cart items' }}">
              <thead>
                <tr>
                  <th scope="col" colspan="2">{{ 'cart.product' | t | default: 'Product' }}</th>
                  <th scope="col">{{ 'cart.price' | t | default: 'Price' }}</th>
                  <th scope="col">{{ 'cart.quantity' | t | default: 'Quantity' }}</th>
                  <th scope="col">{{ 'cart.total' | t | default: 'Total' }}</th>
                </tr>
              </thead>
              <tbody>
                {%- for item in cart.items -%}
                  <tr class="cart-item" data-key="{{ item.key }}">

                    <!-- Product image -->
                    <td style="width:100px;">
                      <a href="{{ item.url }}" class="cart-item__image">
                        {%- if item.image -%}
                          <img
                            src="{{ item.image | image_url: width: 160 }}"
                            alt="{{ item.image.alt | default: item.title | escape }}"
                            loading="lazy"
                            width="80"
                            height="{{ 80 | divided_by: item.image.aspect_ratio | round }}"
                          >
                        {%- endif -%}
                      </a>
                    </td>

                    <!-- Product details -->
                    <td>
                      <div class="cart-item__details">
                        {%- if item.vendor != blank -%}
                          <p class="cart-item__vendor">{{ item.vendor }}</p>
                        {%- endif -%}

                        <a href="{{ item.url }}" class="cart-item__title">{{ item.product_title }}</a>

                        {%- unless item.variant.title == 'Default Title' -%}
                          <p class="cart-item__variant">{{ item.variant.title }}</p>
                        {%- endunless -%}

                        {%- if item.selling_plan_allocation != blank -%}
                          <p class="cart-item__variant">{{ item.selling_plan_allocation.selling_plan.name }}</p>
                        {%- endif -%}

                        <!-- Line item properties -->
                        {%- unless item.properties == empty -%}
                          {%- for property in item.properties -%}
                            {%- unless property.last == blank -%}
                              <p class="cart-item__variant">
                                <em>{{ property.first }}:</em> {{ property.last }}
                              </p>
                            {%- endunless -%}
                          {%- endfor -%}
                        {%- endunless -%}

                        <button
                          type="button"
                          class="cart-item__remove"
                          data-remove-item="{{ forloop.index }}"
                          aria-label="{{ 'cart.remove_item' | t | default: 'Remove' }} {{ item.title | escape }}"
                        >
                          {{ 'cart.remove' | t | default: 'Remove' }}
                        </button>
                      </div>
                    </td>

                    <!-- Price -->
                    <td>
                      <div class="cart-item__price">
                        {%- if item.original_price != item.final_price -%}
                          <span style="color:var(--color-error);">{{ item.final_price | money }}</span>
                          <span style="text-decoration:line-through;color:var(--color-text-lighter);font-size:var(--text-sm);">{{ item.original_price | money }}</span>
                        {%- else -%}
                          {{ item.original_price | money }}
                        {%- endif -%}
                      </div>
                    </td>

                    <!-- Quantity -->
                    <td>
                      <div class="quantity-selector" style="min-width:130px;">
                        <button
                          type="button"
                          class="quantity-selector__btn cart-item-qty-btn"
                          data-action="decrease"
                          data-line="{{ forloop.index }}"
                          aria-label="{{ 'cart.decrease_quantity' | t | default: 'Decrease quantity' }}"
                        >−</button>
                        <input
                          type="number"
                          class="quantity-selector__input cart-item-qty"
                          name="updates[]"
                          value="{{ item.quantity }}"
                          min="0"
                          data-line="{{ forloop.index }}"
                          aria-label="{{ 'cart.item_quantity' | t | default: 'Quantity' }}"
                        >
                        <button
                          type="button"
                          class="quantity-selector__btn cart-item-qty-btn"
                          data-action="increase"
                          data-line="{{ forloop.index }}"
                          aria-label="{{ 'cart.increase_quantity' | t | default: 'Increase quantity' }}"
                        >+</button>
                      </div>
                    </td>

                    <!-- Line total -->
                    <td>
                      <div class="cart-item__total">
                        {{ item.final_line_price | money }}
                      </div>
                    </td>

                  </tr>
                {%- endfor -%}
              </tbody>
            </table>

            <!-- Cart note -->
            <div style="margin-top:var(--space-8);">
              <label
                for="cart-note"
                style="display:block;font-size:var(--text-xs);font-weight:var(--weight-medium);letter-spacing:0.1em;text-transform:uppercase;margin-bottom:var(--space-3);"
              >
                {{ 'cart.note' | t | default: 'Order Notes' }}
              </label>
              <textarea
                id="cart-note"
                name="note"
                rows="3"
                placeholder="{{ 'cart.note_placeholder' | t | default: 'Special instructions for your order...' }}"
                style="width:100%;padding:var(--space-3) var(--space-4);border:1px solid var(--color-border-dark);font-family:var(--font-body);font-size:var(--text-sm);resize:vertical;outline:none;max-width:420px;"
              >{{ cart.note }}</textarea>
            </div>

            <!-- Continue shopping -->
            <div style="margin-top:var(--space-6);">
              <a href="{{ routes.all_products_collection_url }}" class="btn btn--ghost btn--sm">
                {%- render 'icon', icon: 'arrow-left', size: 16 -%}
                {{ 'general.cart.continue_shopping' | t | default: 'Continue Shopping' }}
              </a>
            </div>

          </div><!-- /cart items -->

          <!-- Order Summary -->
          <div class="cart-summary fade-in">
            <h2 class="cart-summary__title">{{ 'cart.order_summary' | t | default: 'Order Summary' }}</h2>

            <!-- Line items count -->
            <div class="cart-summary__line">
              <span>{{ 'cart.subtotal' | t | default: 'Subtotal' }} ({{ cart.item_count }} {{ cart.item_count | pluralize: 'item', 'items' }})</span>
              <span>{{ cart.original_total_price | money }}</span>
            </div>

            {%- if cart.cart_level_discount_applications.size > 0 -%}
              {%- for discount in cart.cart_level_discount_applications -%}
                <div class="cart-summary__line" style="color:var(--color-error);">
                  <span>{{ discount.title }}</span>
                  <span>-{{ discount.total_allocated_amount | money }}</span>
                </div>
              {%- endfor -%}
            {%- endif -%}

            <div class="cart-summary__line">
              <span>{{ 'cart.shipping' | t | default: 'Shipping' }}</span>
              <span style="color:var(--color-success);">{{ 'cart.shipping_calculated_at_checkout' | t | default: 'Calculated at checkout' }}</span>
            </div>

            <div class="cart-summary__total">
              <span>{{ 'cart.estimated_total' | t | default: 'Estimated Total' }}</span>
              <span>{{ cart.total_price | money }}</span>
            </div>

            <p class="cart-summary__note">
              {{ 'cart.taxes_note' | t | default: 'Taxes and shipping calculated at checkout' }}
            </p>

            <div class="cart-summary__actions">
              <button
                type="submit"
                name="checkout"
                class="btn btn--primary btn--full"
              >
                {{ 'cart.checkout' | t | default: 'Proceed to Checkout' }}
              </button>

              {%- if additional_checkout_buttons -%}
                <div>
                  {{ content_for_additional_checkout_buttons }}
                </div>
              {%- endif -%}
            </div>

            <!-- Trust badges -->
            <div style="margin-top:var(--space-6);display:flex;flex-direction:column;gap:var(--space-3);">
              <div style="display:flex;align-items:center;gap:var(--space-3);font-size:var(--text-xs);color:var(--color-text-lighter);">
                {%- render 'icon', icon: 'lock', size: 14 -%}
                {{ 'cart.secure_checkout' | t | default: 'Secure and encrypted checkout' }}
              </div>
              <div style="display:flex;align-items:center;gap:var(--space-3);font-size:var(--text-xs);color:var(--color-text-lighter);">
                {%- render 'icon', icon: 'refresh', size: 14 -%}
                {{ 'cart.free_returns' | t | default: 'Free returns within 30 days' }}
              </div>
              <div style="display:flex;align-items:center;gap:var(--space-3);font-size:var(--text-xs);color:var(--color-text-lighter);">
                {%- render 'icon', icon: 'truck', size: 14 -%}
                {{ 'cart.free_shipping_note' | t | default: 'Free shipping on orders over $150' }}
              </div>
            </div>

          </div><!-- /cart-summary -->

        </div><!-- /cart-layout -->

      </form>

    {%- else -%}

      <!-- Empty Cart -->
      <div class="cart-empty fade-in">
        <div style="margin-bottom:var(--space-6);color:var(--color-text-lighter);opacity:0.3;">
          {%- render 'icon', icon: 'cart', size: 80 -%}
        </div>
        <h2 class="cart-empty__title">{{ 'general.cart.empty' | t | default: 'Your cart is empty' }}</h2>
        <p class="cart-empty__text">
          {{ 'general.cart.empty_description' | t | default: "Looks like you haven't added anything yet. Let's change that." }}
        </p>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary">
          {{ 'general.cart.start_shopping' | t | default: 'Start Shopping' }}
        </a>
      </div>

    {%- endif -%}

  </div>
</div>
