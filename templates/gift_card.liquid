<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ 'Gift card' }} — {{ shop.name }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;600&family=Nunito:wght@300;400;500&display=swap" rel="stylesheet">
  {{ content_for_header }}
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      min-height: 100vh; display: flex; align-items: center; justify-content: center;
      background: #f7f5f2; font-family: 'Nunito', sans-serif; padding: 2rem;
    }
    .gift-card { text-align: center; max-width: 400px; }
    .gift-card__logo {
      font-family: 'Instrument Sans', sans-serif; font-size: 1.5rem; font-weight: 600;
      letter-spacing: 4px; text-transform: uppercase; color: #1c1c1c; margin-bottom: 2rem;
    }
    .gift-card__image { margin-bottom: 2rem; }
    .gift-card__image img { max-width: 100%; height: auto; }
    .gift-card__amount {
      font-family: 'Instrument Sans', sans-serif; font-size: 2.5rem; font-weight: 300;
      letter-spacing: 0.05em; color: #1c1c1c; margin-bottom: 1rem;
    }
    .gift-card__code {
      font-family: monospace; font-size: 1.25rem; letter-spacing: 2px;
      background: #fff; border: 1px solid #e8e8e8; padding: 1rem;
      margin-bottom: 2rem; word-break: break-all;
    }
    .gift-card__shop-link {
      display: inline-block; padding: 0.9rem 2.25rem;
      background: #1c1c1c; color: #fff; text-decoration: none;
      font-family: 'Instrument Sans', sans-serif; font-size: 0.75rem;
      font-weight: 600; letter-spacing: 0.16em; text-transform: uppercase;
    }
  </style>
</head>
<body>
  <div class="gift-card">
    <div class="gift-card__logo">{{ shop.name }}</div>
    <div class="gift-card__image">
      <img src="{{ gift_card | image_url: width: 400 }}" alt="Gift card" width="400" height="256">
    </div>
    <div class="gift-card__amount">{{ gift_card.balance | money }}</div>
    <div class="gift-card__code">{{ gift_card.code }}</div>
    {%- if gift_card.pass_url -%}
      <p style="margin-bottom:1rem;"><a href="{{ gift_card.pass_url }}" style="color:#6b6b6b;font-size:0.85rem;">Add to Apple Wallet</a></p>
    {%- endif -%}
    <a href="{{ shop.url }}" class="gift-card__shop-link">Shop Now</a>
  </div>
</body>
</html>
