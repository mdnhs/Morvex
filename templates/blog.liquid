<div style="max-width:1280px;margin:0 auto;padding:80px 2rem;">
  <h1 style="font-family:'Instrument Sans',sans-serif;font-size:clamp(1.5rem,3vw,2.25rem);font-weight:400;letter-spacing:0.08em;text-transform:uppercase;color:#1c1c1c;margin:0 0 3rem;text-align:center;">{{ blog.title }}</h1>

  <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;">
    {%- for article in blog.articles -%}
      <article>
        <a href="{{ article.url }}" style="text-decoration:none;color:inherit;">
          {%- if article.image -%}
            <div style="aspect-ratio:4/3;overflow:hidden;background:#f0f0f0;margin-bottom:1.25rem;">
              <img src="{{ article.image | image_url: width: 800 }}" alt="{{ article.image.alt | default: article.title | escape }}" loading="lazy" width="800" height="600" style="width:100%;height:100%;object-fit:cover;">
            </div>
          {%- endif -%}
          <time style="font-family:'Nunito',sans-serif;font-size:0.75rem;color:#9b9b9b;" datetime="{{ article.published_at | date: '%Y-%m-%d' }}">{{ article.published_at | date: '%B %d, %Y' }}</time>
          <h2 style="font-family:'Instrument Sans',sans-serif;font-size:1rem;font-weight:500;color:#1c1c1c;margin:0.5rem 0 0.75rem;line-height:1.4;">{{ article.title }}</h2>
          <p style="font-family:'Nunito',sans-serif;font-size:0.875rem;color:#6b6b6b;line-height:1.65;">{{ article.excerpt_or_content | strip_html | truncate: 120 }}</p>
        </a>
      </article>
    {%- endfor -%}
  </div>

  {%- if blog.articles.size == 0 -%}
    <p style="font-family:'Nunito',sans-serif;font-size:1rem;color:#6b6b6b;text-align:center;">No articles yet.</p>
  {%- endif -%}
</div>
