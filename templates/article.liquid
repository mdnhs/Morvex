<article style="max-width:760px;margin:0 auto;padding:80px 2rem;">
  <header style="text-align:center;margin-bottom:3rem;">
    <time style="font-family:'Nunito',sans-serif;font-size:0.75rem;color:#9b9b9b;display:block;margin-bottom:1rem;" datetime="{{ article.published_at | date: '%Y-%m-%d' }}">{{ article.published_at | date: '%B %d, %Y' }}</time>
    <h1 style="font-family:'Instrument Sans',sans-serif;font-size:clamp(1.75rem,3.5vw,2.75rem);font-weight:400;letter-spacing:0.06em;text-transform:uppercase;color:#1c1c1c;margin:0 0 1.5rem;line-height:1.15;">{{ article.title }}</h1>
    <p style="font-family:'Nunito',sans-serif;font-size:0.85rem;color:#9b9b9b;">By {{ article.author }}</p>
  </header>

  {%- if article.image -%}
    <div style="margin-bottom:3rem;">
      <img src="{{ article.image | image_url: width: 1200 }}" alt="{{ article.image.alt | escape }}" width="1200" height="800" style="width:100%;height:auto;">
    </div>
  {%- endif -%}

  <div style="font-family:'Nunito',sans-serif;font-size:1.05rem;line-height:1.85;color:#1c1c1c;">
    {{ article.content }}
  </div>

  <div style="margin-top:3rem;padding-top:2rem;border-top:1px solid #e8e8e8;text-align:center;">
    <a href="{{ blog.url }}" style="font-family:'Instrument Sans',sans-serif;font-size:0.75rem;font-weight:600;letter-spacing:0.15em;text-transform:uppercase;color:#1c1c1c;text-decoration:none;border-bottom:1px solid #1c1c1c;padding-bottom:2px;">Back to {{ blog.title }}</a>
  </div>
</article>
