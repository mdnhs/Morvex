<div style="max-width:800px;margin:0 auto;padding:80px 2rem;">
  <h1 style="font-family:'Instrument Sans',sans-serif;font-size:clamp(1.5rem,3vw,2.25rem);font-weight:400;letter-spacing:0.08em;text-transform:uppercase;color:#1c1c1c;margin:0 0 2rem;text-align:center;">Search</h1>

  <form action="{{ routes.search_url }}" method="get" role="search" style="display:flex;gap:0;max-width:560px;margin:0 auto 3rem;">
    <input
      type="search"
      name="q"
      value="{{ search.terms | escape }}"
      placeholder="Search our store..."
      style="flex:1;padding:14px 20px;font-family:'Nunito',sans-serif;font-size:0.9rem;border:1px solid #d0d0d0;border-right:none;outline:none;"
    >
    <button type="submit" style="padding:14px 28px;background:#1c1c1c;color:#fff;font-family:'Nunito',sans-serif;font-size:11px;font-weight:500;letter-spacing:3px;text-transform:uppercase;border:1px solid #1c1c1c;cursor:pointer;">Search</button>
  </form>

  {%- if search.performed -%}
    {%- if search.results_count > 0 -%}
      <p style="font-family:'Nunito',sans-serif;font-size:0.9rem;color:#6b6b6b;margin-bottom:2rem;text-align:center;">
        {{ search.results_count }} {{ search.results_count | pluralize: 'result', 'results' }} for &ldquo;{{ search.terms }}&rdquo;
      </p>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:2rem;">
        {%- for item in search.results -%}
          <a href="{{ item.url }}" style="text-decoration:none;color:inherit;">
            {%- if item.featured_image -%}
              <div style="aspect-ratio:3/4;overflow:hidden;background:#efefef;margin-bottom:1rem;">
                <img src="{{ item.featured_image | image_url: width: 400 }}" alt="{{ item.featured_image.alt | escape }}" loading="lazy" width="400" height="533" style="width:100%;height:100%;object-fit:cover;">
              </div>
            {%- endif -%}
            <p style="font-family:'Instrument Sans',sans-serif;font-size:1rem;font-weight:400;color:#1c1c1c;margin:0;">{{ item.title }}</p>
          </a>
        {%- endfor -%}
      </div>
    {%- else -%}
      <p style="font-family:'Nunito',sans-serif;font-size:1rem;color:#6b6b6b;text-align:center;">
        No results found for &ldquo;{{ search.terms }}&rdquo;. Please try another search.
      </p>
    {%- endif -%}
  {%- endif -%}
</div>
