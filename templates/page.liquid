{% comment %}
  Page template — simple centered layout for static pages (About, FAQ, Contact, etc.)
{% endcomment %}

<div class="page-template">
  <div class="container">

    <!-- Page Header -->
    <header class="page-template__header fade-in">
      <h1 class="page-template__title">{{ page.title }}</h1>
    </header>

    <!-- Page Content -->
    <div class="page-template__content richtext fade-in fade-in--delay-1">
      {{ page.content }}
    </div>

  </div>
</div>
