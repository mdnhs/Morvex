{% comment %}
  Collection page template — filter sidebar, sort, product grid, pagination.
{% endcomment %}

<!-- Collection Header -->
<div class="collection-header">
  <div class="container">
    {%- if collection.image -%}
      <div style="position:relative;height:320px;overflow:hidden;margin-bottom:var(--space-8);">
        <img
          src="{{ collection.image | image_url: width: 1920 }}"
          srcset="
            {{ collection.image | image_url: width: 768 }} 768w,
            {{ collection.image | image_url: width: 1200 }} 1200w,
            {{ collection.image | image_url: width: 1920 }} 1920w
          "
          sizes="100vw"
          alt="{{ collection.image.alt | default: collection.title | escape }}"
          style="width:100%;height:100%;object-fit:cover;"
          loading="eager"
        >
        <div style="position:absolute;inset:0;background:rgba(0,0,0,0.3);display:flex;align-items:center;justify-content:center;">
          <h1 style="color:#fff;font-family:var(--font-heading);font-size:clamp(2.25rem,5vw,3.75rem);font-weight:300;letter-spacing:0.02em;">
            {{ collection.title }}
          </h1>
        </div>
      </div>
    {%- else -%}
      <h1 class="collection-header__title fade-in">{{ collection.title }}</h1>
      {%- if collection.description != blank -%}
        <div class="collection-header__description richtext fade-in fade-in--delay-1">
          {{ collection.description }}
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>
</div>

<div class="collection-layout">
  <div class="container">

    <!-- Toolbar -->
    <div class="collection-toolbar">
      <div style="display:flex;align-items:center;gap:var(--space-4);">
        <!-- Mobile filter button -->
        <button
          type="button"
          class="btn btn--ghost btn--sm"
          data-filter-open
          style="display:none;"
          id="filter-open-btn"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <line x1="4" y1="6" x2="20" y2="6"/>
            <line x1="4" y1="12" x2="14" y2="12"/>
            <line x1="4" y1="18" x2="10" y2="18"/>
          </svg>
          {{ 'collection.filters' | t | default: 'Filter' }}
        </button>

        <p class="collection-toolbar__count">
          {{ collection.products_count }} {{ 'collection.products_count' | t | default: 'products' }}
        </p>
      </div>

      <div class="collection-toolbar__right">

        <!-- Grid view toggles -->
        <div style="display:flex;gap:var(--space-1);" aria-label="{{ 'collection.grid_view' | t | default: 'Grid view' }}">
          <button
            type="button"
            class="btn btn--icon active"
            data-grid-view="4"
            aria-label="4 columns"
            title="4 columns"
          >
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <rect x="0" y="0" width="3" height="3"/><rect x="4.5" y="0" width="3" height="3"/>
              <rect x="9" y="0" width="3" height="3"/><rect x="13.5" y="0" width="3" height="3"/>
              <rect x="0" y="4.5" width="3" height="3"/><rect x="4.5" y="4.5" width="3" height="3"/>
              <rect x="9" y="4.5" width="3" height="3"/><rect x="13.5" y="4.5" width="3" height="3"/>
              <rect x="0" y="9" width="3" height="3"/><rect x="4.5" y="9" width="3" height="3"/>
              <rect x="9" y="9" width="3" height="3"/><rect x="13.5" y="9" width="3" height="3"/>
            </svg>
          </button>
          <button
            type="button"
            class="btn btn--icon"
            data-grid-view="2"
            aria-label="2 columns"
            title="2 columns"
          >
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <rect x="0" y="0" width="6.5" height="6.5"/>
              <rect x="9.5" y="0" width="6.5" height="6.5"/>
              <rect x="0" y="9.5" width="6.5" height="6.5"/>
              <rect x="9.5" y="9.5" width="6.5" height="6.5"/>
            </svg>
          </button>
        </div>

        <!-- Sort -->
        <label for="sort-select" class="visually-hidden">{{ 'collection.sort_by' | t | default: 'Sort by' }}</label>
        <select
          id="sort-select"
          class="sort-select"
          name="sort_by"
          onchange="window.location.href = window.location.pathname + '?sort_by=' + this.value + '{{ collection.url contains '?' | ternary: '&', '' }}'"
        >
          <option value="manual"{% if collection.sort_by == 'manual' %} selected{% endif %}>{{ 'collection.sort_featured' | t | default: 'Featured' }}</option>
          <option value="best-selling"{% if collection.sort_by == 'best-selling' %} selected{% endif %}>{{ 'collection.sort_best_selling' | t | default: 'Best Selling' }}</option>
          <option value="title-ascending"{% if collection.sort_by == 'title-ascending' %} selected{% endif %}>{{ 'collection.sort_az' | t | default: 'A–Z' }}</option>
          <option value="title-descending"{% if collection.sort_by == 'title-descending' %} selected{% endif %}>{{ 'collection.sort_za' | t | default: 'Z–A' }}</option>
          <option value="price-ascending"{% if collection.sort_by == 'price-ascending' %} selected{% endif %}>{{ 'collection.sort_price_low' | t | default: 'Price: Low to High' }}</option>
          <option value="price-descending"{% if collection.sort_by == 'price-descending' %} selected{% endif %}>{{ 'collection.sort_price_high' | t | default: 'Price: High to Low' }}</option>
          <option value="created-descending"{% if collection.sort_by == 'created-descending' %} selected{% endif %}>{{ 'collection.sort_newest' | t | default: 'Newest' }}</option>
        </select>
      </div>
    </div>

    <!-- Layout: sidebar + grid -->
    <div class="collection-inner">

      <!-- Filters Sidebar -->
      <aside class="filters" aria-label="{{ 'collection.filters_title' | t | default: 'Filters' }}">

        <!-- Mobile close button -->
        <div style="display:none;justify-content:space-between;align-items:center;margin-bottom:var(--space-6);" id="filter-header">
          <h2 style="font-family:var(--font-heading);font-size:var(--text-2xl);font-weight:300;">
            {{ 'collection.filters_title' | t | default: 'Filters' }}
          </h2>
          <button type="button" class="btn btn--icon" data-filter-close aria-label="{{ 'general.accessibility.close' | t | default: 'Close' }}">
            {%- render 'icon', icon: 'close', size: 20 -%}
          </button>
        </div>

        <!-- Availability filter -->
        <div class="filter-group">
          <h3 class="filter-group__title">{{ 'collection.filter_availability' | t | default: 'Availability' }}</h3>
          <div class="filter-option">
            <input
              type="checkbox"
              id="filter-available"
              name="filter.p.available"
              value="1"
              {% if current_tags contains 'available' %}checked{% endif %}
            >
            <label for="filter-available">
              {{ 'collection.filter_in_stock' | t | default: 'In stock' }}
              <span class="filter-option__count">
                ({{ collection.products | where: "available", true | size }})
              </span>
            </label>
          </div>
        </div>

        <!-- Price filter -->
        <div class="filter-group">
          <h3 class="filter-group__title">{{ 'collection.filter_price' | t | default: 'Price' }}</h3>
          <div class="filter-price">
            <div>
              <label for="price-min" style="font-size:var(--text-xs);color:var(--color-text-lighter);display:block;margin-bottom:var(--space-1);">Min</label>
              <input
                type="number"
                id="price-min"
                class="filter-price__input"
                name="filter.v.price.gte"
                placeholder="0"
                min="0"
              >
            </div>
            <div>
              <label for="price-max" style="font-size:var(--text-xs);color:var(--color-text-lighter);display:block;margin-bottom:var(--space-1);">Max</label>
              <input
                type="number"
                id="price-max"
                class="filter-price__input"
                name="filter.v.price.lte"
                placeholder="Any"
                min="0"
              >
            </div>
          </div>
        </div>

        <!-- Tag filters -->
        {%- if collection.all_tags.size > 0 -%}
          <div class="filter-group">
            <h3 class="filter-group__title">{{ 'collection.filter_tags' | t | default: 'Categories' }}</h3>
            {%- for tag in collection.all_tags -%}
              {%- unless tag contains '_' -%}
                <div class="filter-option">
                  <input
                    type="checkbox"
                    id="tag-{{ tag | handleize }}"
                    name="filter.p.tag"
                    value="{{ tag | escape }}"
                    {% if current_tags contains tag %}checked{% endif %}
                  >
                  <label for="tag-{{ tag | handleize }}">
                    {{ tag }}
                  </label>
                </div>
              {%- endunless -%}
            {%- endfor -%}
          </div>
        {%- endif -%}

        <!-- Clear filters link -->
        {%- if current_tags.size > 0 -%}
          <a
            href="{{ collection.url }}"
            style="font-size:var(--text-xs);color:var(--color-text-lighter);text-decoration:underline;"
          >
            {{ 'collection.clear_filters' | t | default: 'Clear all filters' }}
          </a>
        {%- endif -%}

      </aside><!-- /filters -->

      <!-- Product Grid -->
      <div>
        {%- if collection.products.size > 0 -%}
          <div class="product-grid" role="list" id="product-grid">
            {%- for product in collection.products -%}
              <div class="fade-in fade-in--delay-{{ forloop.index | modulo: 4 | plus: 1 }}" role="listitem">
                {%- render 'product-card',
                  product: product,
                  show_vendor: false,
                  show_quick_add: true,
                  index: forloop.index
                -%}
              </div>
            {%- endfor -%}
          </div>
        {%- else -%}
          <div style="padding:var(--space-20) 0;text-align:center;">
            <p style="font-family:var(--font-heading);font-size:var(--text-2xl);font-weight:300;margin-bottom:var(--space-4);">
              {{ 'collection.empty' | t | default: 'No products found' }}
            </p>
            <p style="color:var(--color-text-lighter);margin-bottom:var(--space-8);">
              {{ 'collection.empty_description' | t | default: 'Try adjusting your filters or browse all products.' }}
            </p>
            <a href="{{ routes.all_products_collection_url }}" class="btn btn--ghost">
              {{ 'collection.view_all' | t | default: 'View All Products' }}
            </a>
          </div>
        {%- endif -%}

        <!-- Pagination -->
        {%- if paginate.pages > 1 -%}
          {%- paginate collection.products by 12 -%}
            <nav class="pagination" aria-label="{{ 'general.pagination.label' | t | default: 'Pagination' }}">
              {%- if paginate.previous -%}
                <a href="{{ paginate.previous.url }}" class="pagination__link" aria-label="{{ 'pagination.previous' | t | default: 'Previous page' }}">
                  {%- render 'icon', icon: 'chevron-left', size: 18 -%}
                </a>
              {%- endif -%}

              {%- for part in paginate.parts -%}
                {%- if part.is_link -%}
                  <a href="{{ part.url }}" class="pagination__link">{{ part.title }}</a>
                {%- elsif part.title == paginate.current_page -%}
                  <span class="pagination__link active" aria-current="page">{{ part.title }}</span>
                {%- else -%}
                  <span class="pagination__link" style="border:none;cursor:default;">{{ part.title }}</span>
                {%- endif -%}
              {%- endfor -%}

              {%- if paginate.next -%}
                <a href="{{ paginate.next.url }}" class="pagination__link" aria-label="{{ 'pagination.next' | t | default: 'Next page' }}">
                  {%- render 'icon', icon: 'chevron-right', size: 18 -%}
                </a>
              {%- endif -%}
            </nav>
          {%- endpaginate -%}
        {%- endif -%}

      </div><!-- /product grid wrapper -->

    </div><!-- /collection-inner -->

  </div>
</div>

<!-- Mobile filter overlay -->
<div class="filter-overlay cart-drawer-overlay" style="display:none;" id="filter-overlay"></div>

<style>
  @media (max-width: 768px) {
    #filter-open-btn { display: inline-flex !important; }
    #filter-header { display: flex !important; }
    .filter-overlay { display: block !important; }
  }
</style>
